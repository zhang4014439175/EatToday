<view class="container">
  <!-- 空间快速切换栏 -->
  <view class="space-quick-bar flex-row" bindtap="onTapSpaceSwitcher" wx:if="{{currentSpace}}">
    <view class="space-quick-name">
      <text class="quick-icon">🏠</text>
      <text>{{currentSpace.name || '默认空间'}}</text>
      <text class="quick-arrow">▼</text>
    </view>
    <view class="space-quick-badge">{{currentSpace.type === 'solo' ? '个人' : '群组'}}</view>
  </view>

  <!-- 1. 新增提案表单（常驻展开且高度优化） -->
  <view class="card proposal-form-card" style="padding: 24rpx; margin-bottom: 24rpx;">
    <view class="card-title" style="margin-bottom: 20rpx; padding: 0;">发起去哪玩提案</view>

    <view class="proposal-form">
      <view class="form-group" style="margin-bottom: 16rpx;">
        <input class="form-input" placeholder="主题：想去干嘛 (如看电影/吃火锅)" value="{{newProposal.title}}" bindinput="onInputTitle" style="height: 72rpx;" />
      </view>

      <view class="form-group flex-row flex-between" style="display: flex; gap: 20rpx; margin-bottom: 16rpx; width: 100%; box-sizing: border-box;">
        <picker mode="date" value="{{newProposal.date}}" bindchange="onDateChange" style="flex: 1;">
          <view class="picker-box" style="height: 72rpx; line-height: 72rpx; font-size: 26rpx; border: 1rpx solid rgba(45, 41, 56, 0.12); border-radius: 12rpx; padding: 0 20rpx; background: #FAF9FC; color: #2D2938; box-sizing: border-box;">📅 {{newProposal.date || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{newProposal.time}}" bindchange="onTimeChange" style="flex: 1;">
          <view class="picker-box" style="height: 72rpx; line-height: 72rpx; font-size: 26rpx; border: 1rpx solid rgba(45, 41, 56, 0.12); border-radius: 12rpx; padding: 0 20rpx; background: #FAF9FC; color: #2D2938; box-sizing: border-box;">⏰ {{newProposal.time || '选择时间'}}</view>
        </picker>
      </view>

      <view class="form-group" style="margin-bottom: 16rpx;">
        <input class="form-input" placeholder="📍 地点：在哪个地标见面 (选填)" value="{{newProposal.meeting_location}}" bindinput="onInputLocation" style="height: 72rpx;" />
      </view>

      <view class="form-group" style="margin-bottom: 24rpx;">
        <input class="form-input" placeholder="📝 备注：补充说明 (选填)" value="{{newProposal.notes}}" bindinput="onInputNotes" style="height: 72rpx;" />
      </view>

      <button class="btn btn-primary" hover-class="btn-primary-hover" bindtap="submitProposal" style="height: 76rpx; line-height: 76rpx; font-size: 26rpx;">发送去哪玩提案</button>
    </view>
  </view>

  <!-- 2. 约会列表展示 -->
  <view class="card-title">去哪玩记录</view>
  
  <view class="date-list">
    <view class="card date-item-card date-card-{{item.status}}" wx:for="{{datePlans}}" wx:key="id">
      <view class="date-header flex-row flex-between">
        <text class="date-badge badge-{{item.status}}">{{statusMap[item.status]}}</text>
        <text class="date-time-tag">{{item.meeting_time}}</text>
      </view>

      <view class="date-title">📌 {{item.title}}</view>
      <view class="date-detail" wx:if="{{item.meeting_location}}">📍 地点：{{item.meeting_location}}</view>
      <view class="date-detail" wx:if="{{item.notes}}">📝 备注：{{item.notes}}</view>
      
      <!-- 修改建议展示 -->
      <view class="revision-note-box" wx:if="{{item.status === 'revision_requested'}}">
        <text class="revision-label">💡 对方修改建议：</text>
        <text class="revision-content">{{item.revision_note || '暂无详细要求'}}</text>
      </view>

      <!-- 待确认状态下的审批流转操作栏 (如果是对方发起的) -->
      <view class="action-bar flex-row flex-between" wx:if="{{item.status === 'pending' && item.created_by !== userInfo.id}}">
        <button class="action-btn accept-btn" bindtap="acceptProposal" data-id="{{item.id}}">接受</button>
        <button class="action-btn revise-btn" bindtap="showReviseDialog" data-id="{{item.id}}">修改建议</button>
        <button class="action-btn reject-btn" bindtap="rejectProposal" data-id="{{item.id}}">婉拒</button>
      </view>

      <!-- 待确认状态下的撤销栏 (自己发起的) -->
      <view class="action-bar flex-row flex-between" wx:if="{{item.status === 'pending' && item.created_by === userInfo.id}}">
        <text class="text-muted">等待伴侣确认中...</text>
        <button class="action-btn cancel-btn" bindtap="cancelProposal" data-id="{{item.id}}">撤回</button>
      </view>
    </view>

    <view class="empty-list" wx:if="{{datePlans.length === 0}}">
      当前没有行程记录，快给 TA 发送第一个去哪玩提案吧！
    </view>
  </view>

  <!-- 3. 修改建议弹窗模态框 -->
  <view class="dialog-mask" wx:if="{{reviseDialogVisible}}">
    <view class="dialog-box card">
      <view class="card-title">提出修改建议</view>
      <textarea class="form-input dialog-textarea" placeholder="在此输入您的修改意见，比如：要不推迟一小时？或者换到大悦城？" value="{{tempRevisionNote}}" bindinput="onInputRevisionNote" />
      <view class="dialog-btns flex-row">
        <button class="btn btn-secondary flex-1" hover-class="btn-secondary-hover" bindtap="hideReviseDialog">取消</button>
        <button class="btn btn-primary flex-1" hover-class="btn-primary-hover" bindtap="submitRevision" style="margin-left: 20rpx;">确认提出</button>
      </view>
    </view>
  </view>

  <!-- 4. 约会灵感池 (愿望单) -->
  <view class="card wishlist-card">
    <view class="card-title">想去的地方清单 ({{wishlist.length}})</view>
    
    <!-- 输入栏 -->
    <view class="flex-row add-wish-box">
      <input class="form-input add-input" placeholder="输入想跟 TA 一起去的地方" value="{{newWishName}}" bindinput="onInputWishName" />
      <view class="btn-add" bindtap="addWish">
        <text class="btn-add-text">添加</text>
      </view>
    </view>

    <!-- 愿望清单 -->
    <view class="wish-list">
      <view class="wish-item flex-row flex-between" wx:for="{{wishlist}}" wx:key="id">
        <text class="wish-item-name">⭐ {{item.name}}</text>
        <view class="wish-actions flex-row">
          <view class="wish-to-proposal" bindtap="wishToProposal" data-name="{{item.name}}">提为行程</view>
          <view class="food-delete-btn" bindtap="deleteWish" data-id="{{item.id}}" style="margin-left: 20rpx;">✕</view>
        </view>
      </view>
      <view class="empty-list" wx:if="{{wishlist.length === 0}}" style="text-align: center;">
        <text style="display: block; margin-bottom: 20rpx;">还没有记录游玩愿望，在这里写下你们想去打卡的地方吧！</text>
        <button class="btn-import-preset" bindtap="importPresetWishes" style="background: #7C69C9; color: #FFFFFF; font-size: 24rpx; font-weight: bold; border-radius: 99rpx; padding: 6rpx 30rpx; min-height: 60rpx; height: 60rpx; line-height: 48rpx; display: inline-flex; align-items: center; justify-content: center; border: none; box-shadow: 0 4rpx 10rpx rgba(124, 105, 201, 0.25);">✨ 一键导入常见好玩项目</button>
      </view>
    </view>
  </view>
</view>
