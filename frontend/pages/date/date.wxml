<view class="container">
  <!-- 1. 新增提案表单（折叠展示） -->
  <view class="card proposal-form-card">
    <view class="card-title flex-row flex-between" bindtap="toggleForm">
      <text>💌 发起约会提案</text>
      <text class="toggle-arrow">{{showForm ? '▲ 收起' : '▼ 展开'}}</text>
    </view>

    <view class="proposal-form" wx:if="{{showForm}}">
      <view class="form-group">
        <text class="form-label">约会主题</text>
        <input class="form-input" placeholder="例如：周末去看电影/吃火锅" value="{{newProposal.title}}" bindinput="onInputTitle" />
      </view>

      <view class="form-group flex-row flex-between">
        <view class="half-group">
          <text class="form-label">约会日期</text>
          <picker mode="date" value="{{newProposal.date}}" bindchange="onDateChange">
            <view class="picker-box">{{newProposal.date || '选择日期'}}</view>
          </picker>
        </view>
        <view class="half-group">
          <text class="form-label">具体时间</text>
          <picker mode="time" value="{{newProposal.time}}" bindchange="onTimeChange">
            <view class="picker-box">{{newProposal.time || '选择时间'}}</view>
          </picker>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">见面地点</text>
        <input class="form-input" placeholder="写个地标，比如：万达广场中庭" value="{{newProposal.meeting_location}}" bindinput="onInputLocation" />
      </view>

      <view class="form-group">
        <text class="form-label">约会备注</text>
        <input class="form-input" placeholder="有什么想跟对方提前说的呢？" value="{{newProposal.notes}}" bindinput="onInputNotes" />
      </view>

      <button class="btn btn-primary" hover-class="btn-primary-hover" bindtap="submitProposal">发送约会提案</button>
    </view>
  </view>

  <!-- 2. 约会列表展示 -->
  <view class="card-title">约会行程记录</view>
  
  <view class="date-list">
    <view class="card date-item-card" wx:for="{{datePlans}}" wx:key="id">
      <view class="date-header flex-row flex-between">
        <text class="date-badge badge-{{item.status}}">{{statusMap[item.status]}}</text>
        <text class="date-time-tag">{{item.meeting_time}}</text>
      </view>

      <view class="date-title">📌 {{item.title}}</view>
      <view class="date-detail" wx:if="{{item.meeting_location}}">📍 地点：{{item.meeting_location}}</view>
      <view class="date-detail" wx:if="{{item.notes}}">📝 备注：{{item.notes}}</view>
      
      <!-- 修改建议展示 -->
      <view class="revision-note-box" wx:if="{{item.status === 'revision_requested'}}">
        <text class="revision-label">💡 对方修改建议：</text>
        <text class="revision-content">{{item.revision_note || '暂无详细要求'}}</text>
      </view>

      <!-- 待确认状态下的审批流转操作栏 (如果是对方发起的) -->
      <view class="action-bar flex-row flex-between" wx:if="{{item.status === 'pending' && item.created_by !== userInfo.id}}">
        <button class="action-btn accept-btn" bindtap="acceptProposal" data-id="{{item.id}}">接受</button>
        <button class="action-btn revise-btn" bindtap="showReviseDialog" data-id="{{item.id}}">修改建议</button>
        <button class="action-btn reject-btn" bindtap="rejectProposal" data-id="{{item.id}}">婉拒</button>
      </view>

      <!-- 待确认状态下的撤销栏 (自己发起的) -->
      <view class="action-bar flex-row flex-between" wx:if="{{item.status === 'pending' && item.created_by === userInfo.id}}">
        <text class="text-muted">等待伴侣确认中...</text>
        <button class="action-btn cancel-btn" bindtap="cancelProposal" data-id="{{item.id}}">撤回</button>
      </view>
    </view>

    <view class="empty-list" wx:if="{{datePlans.length === 0}}">
      当前没有行程记录，快给 TA 发送第一个约会提案吧！
    </view>
  </view>

  <!-- 3. 修改建议弹窗模态框 -->
  <view class="dialog-mask" wx:if="{{reviseDialogVisible}}">
    <view class="dialog-box card">
      <view class="card-title">提出修改建议</view>
      <textarea class="form-input dialog-textarea" placeholder="在此输入您的修改意见，比如：要不推迟一小时？或者换到大悦城？" value="{{tempRevisionNote}}" bindinput="onInputRevisionNote" />
      <view class="dialog-btns flex-row">
        <button class="btn btn-secondary flex-1" hover-class="btn-secondary-hover" bindtap="hideReviseDialog">取消</button>
        <button class="btn btn-primary flex-1" hover-class="btn-primary-hover" bindtap="submitRevision" style="margin-left: 20rpx;">确认提出</button>
      </view>
    </view>
  </view>

  <!-- 4. 约会灵感池 (愿望单) -->
  <view class="card wishlist-card">
    <view class="card-title">想去的地方清单 ({{wishlist.length}})</view>
    
    <!-- 输入栏 -->
    <view class="flex-row add-wish-box">
      <input class="form-input add-input" placeholder="输入想跟 TA 一起去的地方" value="{{newWishName}}" bindinput="onInputWishName" />
      <button class="btn-add" bindtap="addWish">添加</button>
    </view>

    <!-- 愿望清单 -->
    <view class="wish-list">
      <view class="wish-item flex-row flex-between" wx:for="{{wishlist}}" wx:key="id">
        <text class="wish-item-name">⭐ {{item.name}}</text>
        <view class="wish-actions flex-row">
          <view class="wish-to-proposal" bindtap="wishToProposal" data-name="{{item.name}}">提为行程</view>
          <view class="food-delete-btn" bindtap="deleteWish" data-id="{{item.id}}" style="margin-left: 20rpx;">✕</view>
        </view>
      </view>
      <view class="empty-list" wx:if="{{wishlist.length === 0}}">
        还没有记录约会愿望，在这里写下你们想去打卡的地方吧！
      </view>
    </view>
  </view>
</view>
