/* ==========================================================================
   我们的美食之书 (Recipe Album) 独立页面样式
   ========================================================================== */

.recipe-container {
  padding: 30rpx 30rpx 140rpx;
  background: #FAF9FC;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 分类胶囊 */
.category-tabs {
  background-color: #F3F0FA;
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #868095;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.tab-active {
  background-color: #7C69C9;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(124, 105, 201, 0.15);
}

/* 工具栏 */
.toolbar {
  justify-content: space-between;
  margin-bottom: 30rpx;
  width: 100%;
  gap: 20rpx;
}

.tool-btn {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid rgba(45, 41, 56, 0.06);
  border-radius: 20rpx;
  padding: 20rpx 0;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #2D2938;
  box-shadow: 0 4rpx 10rpx rgba(45, 41, 56, 0.02);
  transition: all 0.2s ease;
}

.tool-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.tool-btn .icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.add-btn {
  border-color: rgba(124, 105, 201, 0.15);
  color: #7C69C9;
}

.active-red {
  background: #FFF5F5 !important;
  color: #FF4D4F !important;
  border-color: rgba(255, 77, 79, 0.15) !important;
}

/* 网格相册区域 */
.grid-scroll {
  flex: 1;
  height: calc(100vh - 280rpx);
  width: 100%;
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.recipe-card {
  background: #ffffff;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(45, 41, 56, 0.02);
  position: relative;
  transition: all 0.2s ease;
}

/* 抖动状态，示意管理模式 */
.shaking {
  animation: cardWiggle 0.5s infinite alternate ease-in-out;
}

@keyframes cardWiggle {
  0% { transform: rotate(-1deg); }
  100% { transform: rotate(1deg); }
}

/* 勾选框 */
.batch-checkbox {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  background: rgba(45, 41, 56, 0.4);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.batch-checkbox.checked {
  background: #FF4D4F;
}

.checkbox-inner {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

/* 照片展示区 */
.card-image-box {
  width: 100%;
  height: 220rpx;
  position: relative;
  background-color: #FAF9FC;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.03);
}

.placeholder-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.placeholder-text {
  font-size: 20rpx;
  color: #868095;
}

/* 信息卡 */
.card-info {
  padding: 16rpx 20rpx 20rpx;
}

.dish-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2D2938;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.dish-tags {
  font-size: 20rpx;
  color: #7C69C9;
  background: #F3F0FA;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  display: inline-block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.dish-tags-empty {
  font-size: 20rpx;
  color: #868095;
  font-style: italic;
}

/* 空白看板 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #868095;
  padding: 0 40rpx;
}

/* 底部批量删除条 */
.batch-delete-bar {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 77, 79, 0.12);
  box-shadow: 0 12rpx 36rpx rgba(255, 77, 79, 0.08);
  border-radius: 999rpx;
  padding: 16rpx 24rpx 16rpx 36rpx;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  animation: slideUpDeleteBar 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUpDeleteBar {
  from { transform: translateY(80rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.batch-info {
  font-size: 26rpx;
  font-weight: 800;
  color: #2D2938;
}

.highlight-count {
  color: #FF4D4F;
  font-size: 30rpx;
  margin: 0 4rpx;
}

.btn-delete {
  background: #FF4D4F;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  border-radius: 999rpx;
  padding: 14rpx 32rpx;
  border: 0;
  line-height: 1.5;
  margin: 0;
}

/* 模态框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(45, 41, 56, 0.5);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: relative;
  width: 85vw;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 40rpx;
  box-shadow: 0 24rpx 64rpx rgba(45, 41, 56, 0.15);
  box-sizing: border-box;
  animation: modalZoomIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes modalZoomIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header {
  justify-content: space-between;
  margin-bottom: 30rpx;
  width: 100%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #2D2938;
}

.modal-close {
  font-size: 48rpx;
  color: #868095;
  line-height: 1;
}

.form-body {
  width: 100%;
}

.form-item {
  margin-bottom: 24rpx;
  width: 100%;
}

.form-item .label {
  font-size: 24rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 12rpx;
  display: block;
}

.form-item .input {
  background: #FAF9FC;
  border: 1rpx solid rgba(45, 41, 56, 0.08);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #2D2938;
  width: 100%;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-label {
  font-size: 26rpx;
  color: #2D2938;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.modal-footer {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 40rpx;
  width: 100%;
}

.modal-footer .btn {
  margin: 0;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
}

.btn-secondary {
  background: #FAF9FC;
  color: #868095;
  border: 1rpx solid rgba(45, 41, 56, 0.06);
}

.btn-primary {
  background: #7C69C9;
  color: #ffffff;
}
