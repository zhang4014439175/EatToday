<view class="container recipe-container" style="padding: 24rpx; height: 100vh; display: flex; flex-direction: column; box-sizing: border-box;">
  <!-- 工具栏 (添加与批量管理) -->
  <view class="toolbar flex-row" style="margin-bottom: 24rpx; display: flex; gap: 20rpx; width: 100%;">
    <view class="tool-btn add-btn flex-row" bindtap="showAddModal" style="flex: 1; background: #ffffff; border: 1rpx solid rgba(124, 105, 201, 0.15); border-radius: 20rpx; padding: 20rpx 0; display: flex; justify-content: center; align-items: center; font-size: 26rpx; font-weight: 800; color: #7C69C9; box-shadow: 0 4rpx 10rpx rgba(124, 105, 201, 0.02);">
      <text class="icon" style="margin-right: 8rpx;">➕</text>
      <text>新增美食</text>
    </view>
    <view class="tool-btn manage-btn flex-row {{isBatchMode ? 'active-red' : ''}}" bindtap="toggleBatchMode" style="flex: 1; background: #ffffff; border: 1rpx solid rgba(45, 41, 56, 0.06); border-radius: 20rpx; padding: 20rpx 0; display: flex; justify-content: center; align-items: center; font-size: 26rpx; font-weight: 800; color: #2D2938; box-shadow: 0 4rpx 10rpx rgba(45, 41, 56, 0.02);">
      <text class="icon" style="margin-right: 8rpx;">🗑️</text>
      <text>{{isBatchMode ? '取消管理' : '批量管理'}}</text>
    </view>
  </view>

  <!-- 双栏容器 -->
  <view class="meituan-container" style="display: flex; flex: 1; background: #ffffff; border-radius: 24rpx; border: 1rpx solid rgba(45, 41, 56, 0.05); overflow: hidden; height: calc(100vh - 200rpx); width: 100%;">
    <!-- 左栏：侧边栏分类 -->
    <scroll-view scroll-y class="menu-sidebar" style="width: 180rpx; background: #F6F5FA; height: 100%; border-right: 1rpx solid rgba(45, 41, 56, 0.05); flex-shrink: 0;">
      <view 
        wx:for="{{categories}}" 
        wx:key="key"
        class="sidebar-item {{currentCategory === item.key ? 'sidebar-active' : ''}}" 
        bindtap="switchCategory" 
        data-cat="{{item.key}}"
        style="padding: 32rpx 16rpx; font-size: 24rpx; text-align: center; color: {{currentCategory === item.key ? '#7C69C9' : '#868095'}}; font-weight: 700; border-left: 6rpx solid {{currentCategory === item.key ? '#7C69C9' : 'transparent'}}; background-color: {{currentCategory === item.key ? '#ffffff' : 'transparent'}}; transition: all 0.2s ease;"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <!-- 右栏：菜品展示 -->
    <scroll-view scroll-y class="menu-content" style="flex: 1; padding: 20rpx; height: 100%; box-sizing: border-box; background: #ffffff;">
      <view class="menu-dish-item flex-row {{isBatchMode ? 'shaking' : ''}}" wx:for="{{filteredFoods}}" wx:key="id" bindtap="onCardClick" data-item="{{item}}" style="display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(45, 41, 56, 0.04); cursor: pointer;">
        
        <!-- 批量选择勾选框 -->
        <view class="batch-checkbox {{item.selected ? 'checked' : ''}}" wx:if="{{isBatchMode}}" style="margin-right: 20rpx; width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #FF4D4F; display: flex; align-items: center; justify-content: center; background: {{item.selected ? '#FF4D4F' : '#fff'}}; flex-shrink: 0;">
          <text class="checkbox-inner" wx:if="{{item.selected}}" style="color: #fff; font-size: 20rpx; font-weight: bold;">✓</text>
        </view>

        <!-- 菜品配图 -->
        <image class="dish-img" src="{{item.image_url}}" mode="aspectFill" wx:if="{{item.image_url}}" style="width: 80rpx; height: 80rpx; border-radius: 12rpx; margin-right: 20rpx; background: #F8F7FC; flex-shrink: 0;" />
        <view class="dish-img-placeholder" wx:else style="width: 80rpx; height: 80rpx; border-radius: 12rpx; margin-right: 20rpx; background: #F8F7FC; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(45, 41, 56, 0.04); flex-shrink: 0;">
          <span style="font-size: 32rpx; color: #868095;">🍲</span>
        </view>

        <!-- 信息区 -->
        <view class="dish-info" style="flex: 1; min-width: 0;">
          <view style="display: flex; align-items: center; gap: 10rpx;">
            <view class="dish-name" style="font-size: 28rpx; font-weight: 800; color: #2D2938; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%;">{{item.name}}</view>
            <view class="dining-badge" style="font-size: 18rpx; font-weight: 700; padding: 2rpx 10rpx; border-radius: 6rpx; background: {{item.category === 'home' ? 'rgba(124, 105, 201, 0.1)' : 'rgba(255, 123, 137, 0.1)'}}; color: {{item.category === 'home' ? '#7C69C9' : '#FF7B89'}}; flex-shrink: 0;">
              {{item.category === 'home' ? '在家吃' : '出去吃'}}
            </view>
          </view>
          <view class="dish-desc" style="font-size: 22rpx; color: #868095; margin-top: 8rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{item.tags || '主厨特色，极力推荐'}}</view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{filteredFoods.length === 0}}" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 80rpx; text-align: center;">
        <view class="empty-text" style="font-size: 28rpx; font-weight: 800; color: #2D2938; margin-bottom: 10rpx;">美食库空空如也</view>
        <view class="empty-sub" style="font-size: 22rpx; color: #868095; margin-bottom: 24rpx;">开启你们的美食创作之旅吧</view>
        <button class="btn-import-preset" bindtap="importPresetFoods" style="background: #7C69C9; color: #FFFFFF; font-size: 24rpx; font-weight: bold; border-radius: 99rpx; padding: 10rpx 40rpx; min-height: 64rpx; height: 64rpx; line-height: 44rpx; display: inline-flex; align-items: center; justify-content: center; border: none; box-shadow: 0 4rpx 12rpx rgba(124, 105, 201, 0.25);">一键导入预置常见菜品</button>
      </view>
    </scroll-view>
  </view>

  <!-- 底部批量删除确认条 -->
  <view class="batch-delete-bar flex-row" wx:if="{{isBatchMode && selectedCount > 0}}">
    <view class="batch-info">已选择 <text class="highlight-count">{{selectedCount}}</text> 个项目</view>
    <button class="btn-delete" bindtap="deleteSelectedFoods">❌ 批量删除</button>
  </view>

  <!-- 新增/编辑美食弹层 -->
  <view class="modal-overlay" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="hideModal"></view>
    <view class="modal-content">
      <view class="modal-header flex-row">
        <text class="modal-title">{{isEditMode ? '📝 编辑美食信息' : '➕ 新增爱心美食'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>

      <view class="form-body">
        <view class="form-item">
          <text class="label">美食名称</text>
          <input class="input" placeholder="输入美味名称 (如: 咖喱鸡饭)" value="{{formName}}" bindinput="onInputFormName" />
        </view>

        <view class="form-item">
          <text class="label">美食标签 (逗号分隔)</text>
          <input class="input" placeholder="输入美食特点 (如: 热腾腾,超辣)" value="{{formTags}}" bindinput="onInputFormTags" />
        </view>

        <view class="form-item">
          <text class="label">就餐品类分类</text>
          <radio-group class="radio-group" bindchange="onCategoryChange">
            <label class="radio-label">
              <radio value="home" checked="{{formCategory === 'home'}}" color="#7C69C9" />
              爱心私房菜 (在家吃)
            </label>
            <label class="radio-label">
              <radio value="out" checked="{{formCategory === 'out'}}" color="#7C69C9" />
              风味寻宝图 (出去吃)
            </label>
          </radio-group>
        </view>
      </view>

      <view class="modal-footer flex-row">
        <button class="btn btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn btn-primary" bindtap="submitForm">保存提交</button>
      </view>
    </view>
  </view>
</view>
