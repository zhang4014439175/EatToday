.tab-container {
  padding: 8rpx;
  background-color: #F0EFF0;
  border-radius: 999rpx;
  margin-bottom: 36rpx;
  display: flex;
  align-items: center;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 999rpx;
  color: #868095;
  font-weight: 700;
  transition: all 0.2s ease;
}

.tab-active {
  background-color: #ffffff;
  color: #7C69C9;
  font-weight: 800;
  box-shadow: 0 4rpx 16rpx rgba(45, 41, 56, 0.04);
}

.block-hint {
  display: block;
  margin-top: 16rpx;
  color: #868095;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 轮盘展示区域 */
.wheel-card {
  padding: 48rpx 36rpx;
  text-align: center;
}

.wheel-outer {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin: 40rpx auto 48rpx;
  border-radius: 50%;
  border: 10rpx solid #FFFFFF;
  box-shadow: 0 16rpx 40rpx rgba(45, 41, 56, 0.08);
  background-color: #ffffff;
  box-sizing: border-box;
}

.wheel-pointer {
  position: absolute;
  top: -24rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  font-size: 40rpx;
  color: #7C69C9;
  text-shadow: 0 4rpx 8rpx rgba(124, 105, 201, 0.2);
}

.wheel-plate {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  background: conic-gradient(#F3F0FA, #FFFDF7, #F2F7FC, #F0F7F5, #F3F0FA);
  transition: transform 3.5s cubic-bezier(0.1, 0.8, 0.1, 1);
  box-sizing: border-box;
  box-shadow: inset 0 0 40rpx rgba(45, 41, 56, 0.03);
}

.wheel-plate::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(45, 41, 56, 0.08);
  border: 4rpx solid #F3F0FA;
  z-index: 5;
}

.wheel-sector {
  position: absolute;
  top: 0;
  left: 50%;
  width: 50%;
  height: 100%;
  transform-origin: left center;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 48rpx;
  box-sizing: border-box;
}

.sector-text {
  font-size: 26rpx;
  color: #2D2938;
  font-weight: 800;
  writing-mode: vertical-rl;
  text-align: center;
  max-height: 160rpx;
  overflow: hidden;
}

.empty-pool-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #868095;
  font-size: 28rpx;
  font-weight: 700;
}

/* 结果卡片 */
.result-card {
  background: #FFFDFD;
  border: 2rpx dashed rgba(124, 105, 201, 0.3);
  animation: bounceIn 0.5s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  padding: 40rpx;
}

@keyframes bounceIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}

.result-title {
  font-size: 26rpx;
  color: #868095;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.result-name {
  font-size: 64rpx;
  font-weight: 900;
  color: #7C69C9;
  margin: 28rpx 0;
}

/* 投票模块样式 */
.session-status {
  margin-bottom: 32rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  background-color: #F3F0FA;
  color: #7C69C9;
  border: 1rpx solid rgba(124, 105, 201, 0.15);
  font-size: 24rpx;
  font-weight: 800;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
}

.vote-instruction {
  font-size: 26rpx;
  color: #868095;
  line-height: 1.6;
  font-weight: 500;
}

.vote-toolbar {
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.vote-toolbar .vote-instruction {
  flex: 1;
  margin-bottom: 0;
}

.random-vote-btn {
  width: auto;
  min-width: 156rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  font-size: 24rpx;
  line-height: 56rpx;
}

.food-checkbox-list {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.food-checkbox-item {
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(45, 41, 56, 0.08);
  border-radius: 20rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2938;
  transition: all 0.2s ease;
  background-color: #FFFFFF;
}

.food-checkbox-item checkbox {
  margin-right: 18rpx;
}

.checkbox-checked {
  border-color: rgba(124, 105, 201, 0.35);
  background-color: #FFFDFD;
  color: #7C69C9;
}

.food-checkbox-name {
  flex: 1;
}

.food-tag {
  background-color: #F3F0FA;
  color: #7C69C9;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

/* 美食库管理区 */
.add-food-box {
  margin-bottom: 32rpx;
  gap: 16rpx;
}

.add-input {
  flex: 1;
  margin-bottom: 0;
}

.btn-add {
  background: #2A9D8F;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 44rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(42, 157, 143, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-add:active {
  background: #20776C;
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 10rpx rgba(42, 157, 143, 0.1);
}

.food-list {
  max-height: 480rpx;
}

.food-item {
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.05);
  font-size: 28rpx;
  font-weight: 500;
  color: #2D2938;
  align-items: center;
}

.food-item:last-child {
  border-bottom: none;
}

.food-item-name {
  flex: 1;
}

/* ==========================================================================
   爱心小厨房 (Love Kitchen) 样式
   ========================================================================== */

.kitchen-state-card {
  border-left: 8rpx solid #7C69C9;
}

.dish-chip-active {
  background: #7C69C9 !important;
  color: #ffffff !important;
  border-color: #7C69C9 !important;
  box-shadow: 0 6rpx 16rpx rgba(124, 105, 201, 0.15);
}

.cooking-heart-loader {
  animation: heartPulseInfinite 1.4s infinite alternate ease-in-out;
}

.cooking-icon-loader {
  animation: rotateSpinCooking 2.2s infinite linear;
}

.eating-loader {
  animation: chewShake 0.6s infinite ease-in-out;
}

@keyframes heartPulseInfinite {
  0% { transform: scale(0.9); opacity: 0.8; }
  100% { transform: scale(1.2); opacity: 1; text-shadow: 0 0 12rpx rgba(124, 105, 201, 0.4); }
}

@keyframes rotateSpinCooking {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.15); }
  100% { transform: rotate(360deg) scale(1); }
}

@keyframes chewShake {
  0% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-8rpx) scale(1.05) rotate(5deg); }
  100% { transform: translateY(0) scale(1) rotate(-5deg); }
}

.dish-detail-box {
  width: 100%;
}

.dish-name-tag {
  display: block;
}

.chef-action-box {
  width: 100%;
}

.chef-action-box .btn {
  margin: 0 !important;
}

.dish-upload-area {
  transition: all 0.2s ease;
}

.dish-upload-area:active {
  background: #EAE5F6 !important;
  border-color: #7C69C9 !important;
}

.dish-photo-show {
  position: relative;
}

.dish-image {
  box-shadow: 0 12rpx 32rpx rgba(45, 41, 56, 0.08);
}

/* ==========================================================================
   就餐模式切换器 (Eat Mode Switcher) 样式
   ========================================================================== */

.eat-mode-switcher {
  padding: 8rpx;
  background-color: #F1EFF5;
  border-radius: 999rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
}

.eat-mode-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  padding: 18rpx 0;
  border-radius: 999rpx;
  color: #868095;
  font-weight: 700;
  transition: all 0.25s ease;
}

.eat-mode-active {
  background-color: #7C69C9;
  color: #ffffff;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(124, 105, 201, 0.2);
}

/* ==========================================================================
   美团点单式双栏小餐馆 (Meituan Style Ordering) 样式
   ========================================================================== */

.meituan-menu-card {
  box-shadow: 0 16rpx 40rpx rgba(45, 41, 56, 0.04);
}

.sidebar-item {
  position: relative;
  background-color: #F6F5FA;
}

.sidebar-active {
  background-color: #ffffff !important;
  color: #7C69C9 !important;
  border-left-color: #7C69C9 !important;
  font-weight: 800 !important;
}

.dish-btn {
  transition: all 0.15s ease;
  box-sizing: border-box;
}

.dish-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.cart-icon-box {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-cart-bar {
  border-top: 1rpx solid rgba(45, 41, 56, 0.05);
  animation: slideUpIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUpIn {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 结算弹窗 */
.order-confirm-modal {
  animation: fadeIn 0.25s ease;
}

.modal-mask {
  animation: fadeInMask 0.25s ease;
}

.modal-content {
  animation: slideUpModal 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInMask {
  from { background: rgba(45, 41, 56, 0); }
  to { background: rgba(45, 41, 56, 0.6); }
}

@keyframes slideUpModal {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.selected-items-list::-webkit-scrollbar {
  display: none;
}


