<view class="container recipe-container" style="padding: 24rpx; height: 100vh; display: flex; flex-direction: column; box-sizing: border-box;">
  <!-- 工具栏 (添加与批量管理) -->
  <view class="toolbar flex-row" style="margin-bottom: 24rpx; display: flex; gap: 20rpx; width: 100%;">
    <view class="tool-btn add-btn flex-row" bindtap="showAddModal" style="flex: 1; background: #ffffff; border: 1rpx solid rgba(124, 105, 201, 0.15); border-radius: 20rpx; padding: 20rpx 0; display: flex; justify-content: center; align-items: center; font-size: 26rpx; font-weight: 800; color: #7C69C9; box-shadow: 0 4rpx 10rpx rgba(124, 105, 201, 0.02);">
      <text class="icon" style="margin-right: 8rpx;">➕</text>
      <text>新增玩乐</text>
    </view>
    <view class="tool-btn manage-btn flex-row {{isBatchMode ? 'active-red' : ''}}" bindtap="toggleBatchMode" style="flex: 1; background: #ffffff; border: 1rpx solid rgba(45, 41, 56, 0.06); border-radius: 20rpx; padding: 20rpx 0; display: flex; justify-content: center; align-items: center; font-size: 26rpx; font-weight: 800; color: #2D2938; box-shadow: 0 4rpx 10rpx rgba(45, 41, 56, 0.02);">
      <text class="icon" style="margin-right: 8rpx;">🗑️</text>
      <text>{{isBatchMode ? '取消管理' : '批量管理'}}</text>
    </view>
  </view>

  <!-- 双栏容器 -->
  <view class="meituan-container" style="display: flex; flex: 1; background: #ffffff; border-radius: 24rpx; border: 1rpx solid rgba(45, 41, 56, 0.05); overflow: hidden; height: calc(100vh - 200rpx); width: 100%;">
    <!-- 左栏：侧边栏分类 -->
    <scroll-view scroll-y class="menu-sidebar" style="width: 180rpx; background: #F6F5FA; height: 100%; border-right: 1rpx solid rgba(45, 41, 56, 0.05); flex-shrink: 0;">
      <view 
        class="sidebar-item {{currentCategory === 'outdoor' ? 'sidebar-active' : ''}}" 
        bindtap="switchCategory" 
        data-cat="outdoor"
        style="padding: 32rpx 16rpx; font-size: 24rpx; text-align: center; color: {{currentCategory === 'outdoor' ? '#7C69C9' : '#868095'}}; font-weight: 700; border-left: 6rpx solid {{currentCategory === 'outdoor' ? '#7C69C9' : 'transparent'}}; background-color: {{currentCategory === 'outdoor' ? '#ffffff' : 'transparent'}}; transition: all 0.2s ease;"
      >
        户外活动
      </view>
      <view 
        class="sidebar-item {{currentCategory === 'indoor' ? 'sidebar-active' : ''}}" 
        bindtap="switchCategory" 
        data-cat="indoor"
        style="padding: 32rpx 16rpx; font-size: 24rpx; text-align: center; color: {{currentCategory === 'indoor' ? '#7C69C9' : '#868095'}}; font-weight: 700; border-left: 6rpx solid {{currentCategory === 'indoor' ? '#7C69C9' : 'transparent'}}; background-color: {{currentCategory === 'indoor' ? '#ffffff' : 'transparent'}}; transition: all 0.2s ease;"
      >
        室内休闲
      </view>
    </scroll-view>

    <!-- 右栏：愿望展示 -->
    <scroll-view scroll-y class="menu-content" style="flex: 1; padding: 20rpx; height: 100%; box-sizing: border-box; background: #ffffff;">
      <view class="menu-dish-item flex-row {{isBatchMode ? 'shaking' : ''}}" wx:for="{{filteredWishlist}}" wx:key="id" bindtap="onCardClick" data-item="{{item}}" style="display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(45, 41, 56, 0.04); cursor: pointer;">
        
        <!-- 批量选择勾选框 -->
        <view class="batch-checkbox {{item.selected ? 'checked' : ''}}" wx:if="{{isBatchMode}}" style="margin-right: 20rpx; width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #FF4D4F; display: flex; align-items: center; justify-content: center; background: {{item.selected ? '#FF4D4F' : '#fff'}}; flex-shrink: 0;">
          <text class="checkbox-inner" wx:if="{{item.selected}}" style="color: #fff; font-size: 20rpx; font-weight: bold;">✓</text>
        </view>

        <!-- 玩乐配图占位 -->
        <view class="dish-img-placeholder" style="width: 80rpx; height: 80rpx; border-radius: 12rpx; margin-right: 20rpx; background: #F8F7FC; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(45, 41, 56, 0.04); flex-shrink: 0;">
          <span style="font-size: 32rpx; color: #868095;">🗺️</span>
        </view>

        <!-- 信息区 -->
        <view class="dish-info" style="flex: 1; min-width: 0;">
          <view class="dish-name" style="font-size: 28rpx; font-weight: 800; color: #2D2938; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{item.name}}</view>
          <view class="dish-desc" style="font-size: 22rpx; color: #868095; margin-top: 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">想去打卡打卡</view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{filteredWishlist.length === 0}}" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 80rpx; text-align: center;">
        <view class="empty-text" style="font-size: 28rpx; font-weight: 800; color: #2D2938; margin-bottom: 10rpx;">游玩库空空如也</view>
        <view class="empty-sub" style="font-size: 22rpx; color: #868095; margin-bottom: 24rpx;">写下你们想去打卡的地方吧</view>
        <button class="btn-import-preset" bindtap="importPresetWishes" style="background: #7C69C9; color: #FFFFFF; font-size: 24rpx; font-weight: bold; border-radius: 99rpx; padding: 10rpx 40rpx; min-height: 64rpx; height: 64rpx; line-height: 44rpx; display: inline-flex; align-items: center; justify-content: center; border: none; box-shadow: 0 4rpx 12rpx rgba(124, 105, 201, 0.25);">一键导入常见好玩项目</button>
      </view>
    </scroll-view>
  </view>

  <!-- 底部批量删除确认条 -->
  <view class="batch-delete-bar flex-row" wx:if="{{isBatchMode && selectedCount > 0}}">
    <view class="batch-info">已选择 <text class="highlight-count">{{selectedCount}}</text> 个项目</view>
    <button class="btn-delete" bindtap="deleteSelectedWishes">❌ 批量删除</button>
  </view>

  <!-- 新增/编辑约会弹层 -->
  <view class="modal-overlay" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="hideModal"></view>
    <view class="modal-content">
      <view class="modal-header flex-row">
        <text class="modal-title">{{isEditMode ? '📝 编辑游玩项目' : '➕ 新增游玩项目'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>

      <view class="form-body">
        <view class="form-item">
          <text class="label">项目名称</text>
          <input class="input" placeholder="输入想去打卡的地方 (如: 抓娃娃/爬香山)" value="{{formName}}" bindinput="onInputFormName" />
        </view>
      </view>

      <view class="modal-footer flex-row" style="display: flex; justify-content: flex-end; width: 100%; gap: 16rpx;">
        <button class="btn btn-secondary" bindtap="hideModal" style="margin-right: auto; flex: 1;">取消</button>
        <button class="btn btn-secondary" bindtap="wishToProposal" wx:if="{{isEditMode}}" style="background-color: #FAF9FC; color: #7C69C9; border-color: rgba(124, 105, 201, 0.15); flex: 1;">📌 提为行程</button>
        <button class="btn btn-primary" bindtap="submitForm" style="flex: 1;">保存提交</button>
      </view>
    </view>
  </view>
</view>
