<view class="container recipe-container">
  <!-- 工具栏 (添加与批量管理) -->
  <view class="toolbar flex-row">
    <view class="tool-btn add-btn flex-row" bindtap="showAddModal">
      <text class="icon">➕</text>
      <text>新增项目</text>
    </view>
    <view class="tool-btn manage-btn flex-row {{isBatchMode ? 'active-red' : ''}}" bindtap="toggleBatchMode">
      <text class="icon">🗑️</text>
      <text>{{isBatchMode ? '取消管理' : '批量管理'}}</text>
    </view>
  </view>

  <!-- 网格灵感相册墙 -->
  <scroll-view class="grid-scroll" scroll-y="true">
    <view class="recipe-grid">
      <view class="recipe-card {{isBatchMode ? 'shaking' : ''}}" wx:for="{{wishlist}}" wx:key="id" bindtap="onCardClick" data-item="{{item}}">
        <!-- 批量选择勾选框圈 -->
        <view class="batch-checkbox {{item.selected ? 'checked' : ''}}" wx:if="{{isBatchMode}}">
          <text class="checkbox-inner" wx:if="{{item.selected}}">✓</text>
        </view>

        <!-- 卡片图标展示框 -->
        <view class="card-image-box">
          <view class="card-img-placeholder">
            <text class="placeholder-icon">🗺️</text>
            <text class="placeholder-text">想去打卡</text>
          </view>
        </view>

        <!-- 信息区 -->
        <view class="card-info">
          <view class="dish-name">{{item.name}}</view>
          <view class="dish-tags">⭐ 趣玩项目</view>
        </view>
      </view>
    </view>

    <!-- 空列表提示 -->
    <view class="empty-state" wx:if="{{wishlist.length === 0}}">
      <view class="empty-icon">🗺️</view>
      <view class="empty-text">趣玩库空空如也</view>
      <view class="empty-sub">点击上方「新增项目」开启你们的游玩清单吧</view>
      <button class="btn-import-preset" bindtap="importPresetWishes" style="margin-top: 30rpx; background: #7C69C9; color: #FFFFFF; font-size: 26rpx; font-weight: bold; border-radius: 99rpx; padding: 10rpx 40rpx; min-height: 70rpx; height: 70rpx; line-height: 50rpx; display: inline-flex; align-items: center; justify-content: center; border: none; box-shadow: 0 4rpx 12rpx rgba(124, 105, 201, 0.3);">✨ 一键导入常见好玩项目</button>
    </view>
  </scroll-view>

  <!-- 底部批量删除确认条 -->
  <view class="batch-delete-bar flex-row" wx:if="{{isBatchMode && selectedCount > 0}}">
    <view class="batch-info">已选择 <text class="highlight-count">{{selectedCount}}</text> 个项目</view>
    <button class="btn-delete" bindtap="deleteSelectedWishes">❌ 批量删除</button>
  </view>

  <!-- 新增/编辑美食弹层 -->
  <view class="modal-overlay" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="hideModal"></view>
    <view class="modal-content">
      <view class="modal-header flex-row">
        <text class="modal-title">{{isEditMode ? '📝 编辑趣玩项目' : '➕ 新增趣玩项目'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>

      <view class="form-body">
        <view class="form-item">
          <text class="label">项目名称</text>
          <input class="input" placeholder="输入想去打卡的地方 (如: 抓娃娃/爬香山)" value="{{formName}}" bindinput="onInputFormName" />
        </view>
      </view>

      <view class="modal-footer flex-row" style="display: flex; justify-content: flex-end; width: 100%; gap: 16rpx;">
        <button class="btn btn-secondary" bindtap="hideModal" style="margin-right: auto; flex: 1;">取消</button>
        <button class="btn btn-secondary" bindtap="wishToProposal" wx:if="{{isEditMode}}" style="background-color: #FAF9FC; color: #7C69C9; border-color: rgba(124, 105, 201, 0.15); flex: 1;">📌 提为行程</button>
        <button class="btn btn-primary" bindtap="submitForm" style="flex: 1;">保存提交</button>
      </view>
    </view>
  </view>
</view>
