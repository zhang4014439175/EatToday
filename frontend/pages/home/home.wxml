<view class="container {{calendarExpanded ? 'container-expanded' : ''}}">



  <!-- 首页情侣互动日历 -->
  <view class="card calendar-card">
    <view class="calendar-header flex-row flex-between">
      <view class="month-switch flex-row">
        <view class="arrow-btn" bindtap="prevMonth">◀</view>
        <text class="current-month-text">{{currentYear}}年{{currentMonth}}月</text>
        <view class="arrow-btn" bindtap="nextMonth">▶</view>
      </view>
      <text class="back-today-btn" bindtap="backToToday">回今天</text>
    </view>

    <!-- 星期表头 -->
    <view class="week-header flex-row">
      <text class="week-day weekend">日</text>
      <text class="week-day">一</text>
      <text class="week-day">二</text>
      <text class="week-day">三</text>
      <text class="week-day">四</text>
      <text class="week-day">五</text>
      <text class="week-day weekend">六</text>
    </view>

    <!-- 日历格子网格 -->
    <view class="calendar-grid">
      <view 
        class="grid-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isSelected ? 'selected-day' : ''}} {{item.isToday ? 'today-day' : ''}}" 
        wx:for="{{calendarDays}}" 
        wx:key="dateStr" 
        bindtap="selectDay" 
        data-day="{{item}}"
      >
        <text class="day-number">{{item.day}}</text>
        
        <!-- 彩色日程标记点 (Dots) -->
        <view class="day-dots flex-row">
          <view class="dot dot-anniversary" wx:if="{{item.hasAnniversary}}"></view>
          <view class="dot dot-date" wx:if="{{item.hasDate}}"></view>
          <view class="dot dot-kitchen" wx:if="{{item.hasKitchen}}"></view>
          <view class="dot dot-food" wx:if="{{item.hasFood}}"></view>
          <view class="dot dot-custom" wx:if="{{item.hasCustom}}"></view>
        </view>
      </view>
    </view>

    <!-- 展开/收起切换按钮 -->
    <view class="calendar-toggle-btn flex-row" bindtap="toggleCalendar">
      <text>{{calendarExpanded ? '▲ 收起日历' : '▼ 展开完整日历'}}</text>
    </view>
  </view>

  <!-- 点击天数展示的 Agenda 日程抽屉 -->
  <view class="card agenda-drawer" wx:if="{{selectedDayAgenda}}">
    <view class="agenda-header flex-row flex-between">
      <view class="agenda-title-wrap">
        <text class="agenda-title">{{selectedDayAgenda.dateStr}} 的日常</text>
        <text class="agenda-count">（{{selectedDayAgenda.events.length}}项）</text>
      </view>
      <view style="display: flex; gap: 12rpx; align-items: center;">
        <view class="btn-add-custom btn-manage-anniversary" bindtap="goToAnniversary">纪念日</view>
        <view class="btn-add-custom" bindtap="showAddCustomDialog">备忘录</view>
      </view>
    </view>

    <!-- 日程事项列表 -->
    <scroll-view class="agenda-list" scroll-y="true" enhanced="true" show-scrollbar="true">
      <view class="agenda-item flex-row" wx:for="{{selectedDayAgenda.events}}" wx:key="uniqueId">
        <view class="agenda-dot-line">
          <view class="agenda-dot dot-{{item.type}}"></view>
          <view class="agenda-line" wx:if="{{index < selectedDayAgenda.events.length - 1}}"></view>
        </view>
        <view class="agenda-body flex-1">
          <view class="agenda-content">
            <text class="agenda-type-tag tag-{{item.type}}">[{{item.typeText}}]</text>
            <text class="agenda-time-inline" wx:if="{{item.time}}" style="font-size: 24rpx; font-weight: 800; color: #7C69C9; margin-right: 12rpx;">{{item.time}}</text>
            <text class="agenda-text">{{item.displayTitle}}</text>
            <text class="agenda-subtext" wx:if="{{item.location}}"> {{item.location}}</text>
          </view>
        </view>
      </view>

      <view class="empty-agenda" wx:if="{{selectedDayAgenda.events.length === 0}}">
        这天还没有记录，点击右上角「备忘录」添加或管理备忘。
      </view>
    </scroll-view>
  </view>
  <view class="focus-grid">
    <!-- 看板 1: 今天吃什么 -->
    <view class="card flex-row flex-between today-card today-food" bindtap="onCardTap" data-key="food">
      <view class="today-left">
        <view class="today-label" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <text>🍕 今天吃什么</text>
          <view style="display: flex; gap: 8rpx; align-items: center;">
            <text class="today-space-tag" wx:if="{{todayFoodSpace}}" style="font-size: 18rpx; font-weight: 800; color: #7C69C9; background: #F3F0FA; padding: 3rpx 10rpx; border-radius: 6rpx; line-height: 1;">{{todayFoodSpace}}</text>
            <text class="today-time-tag" wx:if="{{todayFoodTime}}" style="font-size: 20rpx; font-weight: 800; color: #E9C46A; background: #FFFDF6; padding: 3rpx 10rpx; border-radius: 6rpx; line-height: 1;">{{todayFoodTime}}</text>
          </view>
        </view>
        <!-- 如果未登录显示“请先登录”，已登录且有内容显示具体食物，没有则显示推荐文案 -->
        <view class="today-value" style="margin-top: 4rpx; color: {{todayFood === '请先登录' ? '#B5B2C0' : '#2D2938'}}; font-size: {{todayFood === '请先登录' ? '24rpx' : '28rpx'}}; font-weight: {{todayFood === '请先登录' ? '700' : '800'}};">
          {{todayFood || '还在纠结？点击抽个签吧！'}}
        </view>
      </view>
      <view class="today-arrow">➔</view>
    </view>

    <!-- 看板 2: 今日去哪玩 -->
    <view class="card flex-row flex-between today-card today-date" bindtap="onCardTap" data-key="date">
      <view class="today-left">
        <view class="today-label" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <text>📍 今日去哪玩</text>
          <view style="display: flex; gap: 8rpx; align-items: center;">
            <text class="today-space-tag" wx:if="{{todayDateSpace}}" style="font-size: 18rpx; font-weight: 800; color: #7C69C9; background: #F3F0FA; padding: 3rpx 10rpx; border-radius: 6rpx; line-height: 1;">{{todayDateSpace}}</text>
            <text class="today-time-tag" wx:if="{{todayDateTime}}" style="font-size: 20rpx; font-weight: 800; color: #2A9D8F; background: #F4FAF9; padding: 3rpx 10rpx; border-radius: 6rpx; line-height: 1;">{{todayDateTime}}</text>
          </view>
        </view>
        <!-- 如果未登录显示“请先登录”，已登录且有内容显示具体行程，没有则显示推荐文案 -->
        <view class="today-value" style="margin-top: 4rpx; color: {{todayDate === '请先登录' ? '#B5B2C0' : '#2D2938'}}; font-size: {{todayDate === '请先登录' ? '24rpx' : '28rpx'}}; font-weight: {{todayDate === '请先登录' ? '700' : '800'}};">
          {{todayDate || '今天暂无确认的游玩计划'}}
        </view>
      </view>
      <view class="today-arrow">➔</view>
    </view>
  </view>
</view>
