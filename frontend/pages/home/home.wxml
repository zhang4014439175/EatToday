<view class="container">

  <!-- 首页情侣互动日历 -->
  <view class="card calendar-card">
    <view class="calendar-header flex-row flex-between">
      <view class="month-switch flex-row">
        <view class="arrow-btn" bindtap="prevMonth">◀</view>
        <text class="current-month-text">{{currentYear}}年{{currentMonth}}月</text>
        <view class="arrow-btn" bindtap="nextMonth">▶</view>
      </view>
      <text class="back-today-btn" bindtap="backToToday">回今天</text>
    </view>

    <!-- 星期表头 -->
    <view class="week-header flex-row">
      <text class="week-day weekend">日</text>
      <text class="week-day">一</text>
      <text class="week-day">二</text>
      <text class="week-day">三</text>
      <text class="week-day">四</text>
      <text class="week-day">五</text>
      <text class="week-day weekend">六</text>
    </view>

    <!-- 日历格子网格 -->
    <view class="calendar-grid">
      <view 
        class="grid-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isSelected ? 'selected-day' : ''}} {{item.isToday ? 'today-day' : ''}}" 
        wx:for="{{calendarDays}}" 
        wx:key="dateStr" 
        bindtap="selectDay" 
        data-day="{{item}}"
      >
        <text class="day-number">{{item.day}}</text>
        
        <!-- 彩色日程标记点 (Dots) -->
        <view class="day-dots flex-row">
          <view class="dot dot-anniversary" wx:if="{{item.hasAnniversary}}"></view>
          <view class="dot dot-date" wx:if="{{item.hasDate}}"></view>
          <view class="dot dot-kitchen" wx:if="{{item.hasKitchen}}"></view>
          <view class="dot dot-food" wx:if="{{item.hasFood}}"></view>
          <view class="dot dot-custom" wx:if="{{item.hasCustom}}"></view>
        </view>
      </view>
    </view>

    <!-- 展开/收起切换按钮 -->
    <view class="calendar-toggle-btn flex-row" bindtap="toggleCalendar">
      <text>{{calendarExpanded ? '▲ 收起日历' : '▼ 展开完整日历'}}</text>
    </view>
  </view>

  <!-- 点击天数展示的 Agenda 日程抽屉 -->
  <view class="card agenda-drawer" wx:if="{{selectedDayAgenda}}">
    <view class="agenda-header flex-row flex-between">
      <text class="agenda-title">{{selectedDayAgenda.dateStr}} 的日常</text>
      <view class="btn-add-custom" bindtap="showAddCustomDialog">➕ 添加备忘</view>
    </view>

    <!-- 日程事项列表 -->
    <scroll-view class="agenda-list agenda-scroll" scroll-y="true" enhanced="true" show-scrollbar="true">
      <view class="agenda-item flex-row" wx:for="{{selectedDayAgenda.events}}" wx:key="uniqueId">
        <view class="agenda-dot-line">
          <view class="agenda-dot dot-{{item.type}}"></view>
          <view class="agenda-line" wx:if="{{index < selectedDayAgenda.events.length - 1}}"></view>
        </view>
        <view class="agenda-body flex-1">
          <view class="agenda-content">
            <text class="agenda-type-tag tag-{{item.type}}">[{{item.typeText}}]</text>
            <text class="agenda-time-inline" wx:if="{{item.time}}" style="font-size: 24rpx; font-weight: 800; color: #7C69C9; margin-right: 12rpx;">{{item.time}}</text>
            <text class="agenda-text">{{item.title}}</text>
            <text class="agenda-subtext" wx:if="{{item.location}}"> 📍{{item.location}}</text>
          </view>
        </view>
        <view class="agenda-action" wx:if="{{item.type === 'custom'}}">
          <text class="agenda-delete-btn" bindtap="deleteCustomEvent" data-id="{{item.id}}">✕</text>
        </view>
      </view>

      <view class="empty-agenda" wx:if="{{selectedDayAgenda.events.length === 0}}">
        这天平平淡淡，没有记录备忘，点击上方「添加备忘」记一笔吧！
      </view>
    </scroll-view>
  </view>

  <!-- 添加自定义事件弹窗 -->
  <view class="dialog-overlay" wx:if="{{showCustomDialog}}">
    <view class="dialog-mask" bindtap="hideAddCustomDialog"></view>
    <view class="dialog-box card">
      <view class="card-title">📝 添加一日备忘</view>
      <view class="dialog-form">
        <view class="form-group">
          <text class="form-label">备忘内容</text>
          <input class="form-input" placeholder="输入要做的琐事或提醒" value="{{customDialogText}}" bindinput="onInputCustomText" style="height: 80rpx;" />
        </view>
        <view class="form-group">
          <text class="form-label">具体时间 (选填)</text>
          <picker mode="time" value="{{customDialogTime}}" bindchange="onCustomTimeChange">
            <view class="picker-box" style="height: 80rpx; line-height: 80rpx; padding: 0 20rpx; border: 1rpx solid rgba(45,41,56,0.12); border-radius: 10rpx; background: #fff;">{{customDialogTime || '选择时间 (点击更改)'}}</view>
          </picker>
        </view>
      </view>
      <view class="dialog-btns flex-row" style="margin-top: 30rpx;">
        <button class="btn btn-secondary flex-1" bindtap="hideAddCustomDialog">取消</button>
        <button class="btn btn-primary flex-1" bindtap="submitCustomEvent" style="margin-left: 20rpx;">确认保存</button>
      </view>
    </view>
  </view>

  <view class="focus-grid">
    <view
      class="card focus-card {{item.urgent ? 'urgent-card' : ''}}"
      wx:for="{{focusCards}}"
      wx:key="key"
      bindtap="onFocusCardTap"
      data-key="{{item.key}}"
    >
      <view class="focus-card-head">
        <text class="focus-icon">{{item.icon}}</text>
        <text class="focus-label">{{item.label}}</text>
      </view>
      <view class="focus-title">{{item.title}}</view>
      <view class="focus-meta">{{item.meta}}</view>
    </view>
  </view>

  <view class="memo-modal-overlay" wx:if="{{showMemoModal}}">
    <view class="memo-modal-mask" bindtap="closeMemoManager"></view>
    <view class="memo-modal card">
      <view class="memo-modal-header flex-row flex-between">
        <view>
          <view class="memo-modal-title">备忘录管理</view>
          <view class="memo-modal-subtitle">管理当前空间的日常提醒</view>
        </view>
        <view class="memo-close" bindtap="closeMemoManager">✕</view>
      </view>

      <scroll-view class="memo-list" scroll-y="true" enhanced="true" show-scrollbar="true">
        <view class="memo-item flex-row" wx:for="{{memoList}}" wx:key="id">
          <view class="memo-item-main">
            <view class="memo-item-title">{{item.title}}</view>
            <view class="memo-item-meta">{{item.displayDate}} {{item.displayTime}} · {{item.creatorName}}</view>
          </view>
          <view class="memo-delete" bindtap="deleteMemoFromManager" data-id="{{item.id}}">✕</view>
        </view>
        <view class="memo-empty" wx:if="{{memoList.length === 0}}">还没有备忘，下面添加一条吧。</view>
      </scroll-view>

      <view class="memo-form">
        <input class="form-input memo-input" placeholder="输入备忘内容" value="{{memoDialogText}}" bindinput="onMemoTextInput" />
        <view class="memo-picker-row">
          <picker mode="date" value="{{memoDialogDate}}" bindchange="onMemoDateChange">
            <view class="memo-picker">{{memoDialogDate}}</view>
          </picker>
          <picker mode="time" value="{{memoDialogTime}}" bindchange="onMemoTimeChange">
            <view class="memo-picker">{{memoDialogTime || '选择时间'}}</view>
          </picker>
        </view>
        <button class="btn btn-primary memo-add-btn" bindtap="addMemoFromManager">添加备忘</button>
      </view>
    </view>
  </view>
</view>
