.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  overflow: hidden;
}

.container-expanded {
  height: auto;
  min-height: 100vh;
  overflow: visible;
}

.love-header {
  background-color: #F3F0FA;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
  text-align: center;
  padding: 60rpx 40rpx;
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.heart-icon {
  font-size: 64rpx;
  color: #7C69C9;
  display: inline-block;
  z-index: 2;
  margin-bottom: 12rpx;
  animation: heartbeat 2s infinite ease-in-out;
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  12% { transform: scale(1.15); }
  24% { transform: scale(1); }
  36% { transform: scale(1.15); }
  60% { transform: scale(1); }
}

.love-days-title {
  font-size: 26rpx;
  color: #868095;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 8rpx;
  z-index: 2;
}

.love-days-num {
  font-size: 96rpx;
  font-weight: 900;
  color: #2D2938;
  margin: 8rpx 0 20rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  z-index: 2;
}

.days-unit {
  font-size: 32rpx;
  font-weight: 700;
  color: #868095;
  margin-left: 12rpx;
}

.love-partner-info {
  font-size: 26rpx;
  color: #2D2938;
  background-color: #ffffff;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 36rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(124, 105, 201, 0.03);
  z-index: 2;
}

.partner-name {
  font-weight: 800;
  color: #7C69C9;
}

.heart-connector {
  color: #7C69C9;
  margin: 0 16rpx;
  font-size: 28rpx;
  animation: pulse 1.5s infinite alternate ease-in-out;
}

@keyframes pulse {
  0% { opacity: 0.5; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1.1); }
}

/* 今日看板卡片 */
.today-card {
  min-height: 118rpx;
  padding: 24rpx 28rpx;
  align-items: center;
  margin-bottom: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
  box-sizing: border-box;
}

.today-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 26rpx;
  bottom: 26rpx;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #7C69C9;
}

.today-card:active {
  transform: scale(0.985);
  box-shadow: 0 8rpx 24rpx rgba(45, 41, 56, 0.02);
}

.today-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-right: 16rpx;
}

.today-label {
  font-size: 22rpx;
  color: #868095;
  margin-bottom: 6rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.today-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  line-height: 1.24;
}

.today-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background-color: #F3F0FA;
  color: #7C69C9;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.today-card:active .today-arrow {
  background-color: #EAE5F6;
}

/* 纪念日快捷卡片 */
.anniversary-shortcut {
  background-color: #FFFDF7;
  border-left: 0;
  border: 1rpx solid rgba(233, 196, 106, 0.15);
  padding: 30rpx 36rpx;
  position: relative;
}

.anniversary-shortcut::before {
  content: "";
  position: absolute;
  left: 0;
  top: 30rpx;
  bottom: 30rpx;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #E9C46A;
}

.anniversary-label {
  font-size: 24rpx;
  color: #8F7E68;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.anniversary-content {
  font-size: 28rpx;
  color: #2D2938;
  font-weight: 500;
  line-height: 1.6;
}

.anniversary-name {
  color: #868095;
}

.anniversary-countdown {
  font-size: 42rpx;
  font-weight: 900;
  color: #7C69C9;
  margin: 0 8rpx;
}

/* 日历主卡片 */
.calendar-card {
  padding: 30rpx 20rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.calendar-header {
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.current-month-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D2938;
  margin: 0 30rpx;
}

.arrow-btn {
  font-size: 26rpx;
  color: #7C69C9;
  padding: 10rpx 20rpx;
  cursor: pointer;
  background-color: #F3F0FA;
  border-radius: 999rpx;
}

.back-today-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: #7C69C9;
  padding: 8rpx 20rpx;
  background-color: #F3F0FA;
  border-radius: 999rpx;
}

/* 星期表头 */
.week-header {
  margin-bottom: 10rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #868095;
  padding: 10rpx 0;
}

.weekend {
  color: #FF6B6B;
}

/* 日历格子 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.grid-day {
  width: 14.28%;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 16rpx;
  margin: 4rpx 0;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.day-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2938;
}

.other-month .day-number {
  color: #C2BFCA;
}

/* 选中与今日状态 */
.selected-day {
  background-color: #F3F0FA;
  border: 1rpx solid rgba(124, 105, 201, 0.2);
}

.selected-day .day-number {
  color: #7C69C9;
}

.today-day {
  background-color: #7C69C9;
}

.today-day .day-number {
  color: #ffffff;
  font-weight: 900;
}

/* 彩色标记点 */
.day-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
  height: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-anniversary { background-color: #FF6B6B; } /* 红色 */
.dot-date { background-color: #7C69C9; }        /* 紫色 */
.dot-kitchen { background-color: #2A9D8F; }     /* 绿色 */
.dot-food { background-color: #E9C46A; }        /* 黄色 */
.dot-custom { background-color: #4A90E2; }      /* 蓝色 */

.today-day .dot {
  background-color: #ffffff !important; /* 今日格子的标记点均设为白色 */
}

/* 日程小抽屉 */
.agenda-drawer {
  padding: 30rpx 36rpx;
  margin-bottom: 12rpx;
  animation: slideDownAgenda 0.3s ease-out;
  flex: 1;
  height: auto;
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.container-expanded .agenda-drawer {
  flex: none;
  height: 320rpx;
  min-height: 320rpx;
}

@keyframes slideDownAgenda {
  from { transform: translateY(-10rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.agenda-header {
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.06);
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}

.agenda-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
}

.agenda-title-wrap {
  display: flex;
  align-items: baseline;
  min-width: 0;
  flex: 1;
}

.agenda-count {
  font-size: 22rpx;
  font-weight: 700;
  color: #9A95A8;
  margin-left: 4rpx;
  white-space: nowrap;
}

.btn-add-custom {
  font-size: 23rpx;
  font-weight: 700;
  color: #7C69C9;
  background-color: #F3F0FA;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

/* 事项列表 */
.agenda-list {
  flex: 1;
  height: 0;
  min-height: 0;
  box-sizing: border-box;
}

.agenda-item {
  margin-bottom: 10rpx;
  align-items: flex-start;
}

.agenda-dot-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 24rpx;
  margin-right: 16rpx;
  margin-top: 8rpx;
}

.agenda-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #868095;
}

.agenda-dot.dot-anniversary { background-color: #FF6B6B; }
.agenda-dot.dot-date { background-color: #7C69C9; }
.agenda-dot.dot-kitchen { background-color: #2A9D8F; }
.agenda-dot.dot-food { background-color: #E9C46A; }
.agenda-dot.dot-custom { background-color: #4A90E2; }

.agenda-line {
  width: 2rpx;
  height: 26rpx;
  background-color: rgba(45, 41, 56, 0.08);
  margin-top: 4rpx;
}

.agenda-body {
  display: flex;
  flex-direction: column;
}

.agenda-time {
  font-size: 22rpx;
  color: #868095;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.agenda-content {
  font-size: 26rpx;
  color: #2D2938;
  font-weight: 500;
  display: block;
  line-height: 1.35;
}

.agenda-type-tag {
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 8rpx;
  display: inline-block;
}

.agenda-time-inline {
  font-size: 24rpx;
  font-weight: 800;
  color: #7C69C9;
  margin-right: 12rpx;
  display: inline-block;
}

.tag-anniversary { color: #FF6B6B; }
.tag-date { color: #7C69C9; }
.tag-kitchen { color: #2A9D8F; }
.tag-food { color: #E9C46A; }
.tag-custom { color: #4A90E2; }

.agenda-text {
  font-weight: 700;
  display: inline;
}

.agenda-subtext {
  color: #868095;
  margin-left: 6rpx;
  display: inline;
}

.empty-agenda {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #868095;
  line-height: 1.6;
}

/* 弹窗遮罩 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(45, 41, 56, 0.4);
  backdrop-filter: blur(4rpx);
}

.dialog-box {
  position: relative;
  z-index: 2;
  width: 80%;
  padding: 40rpx;
  background-color: #ffffff;
  border-radius: 28rpx;
}

.calendar-toggle-btn {
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 0;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(45, 41, 56, 0.05);
  font-size: 24rpx;
  font-weight: 700;
  color: #7C69C9;
  cursor: pointer;
  width: 100%;
  text-align: center;
}

.focus-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;          /* 上下行卡片之间的垂直行距 */
  margin-top: 12rpx;   /* 与上方日程部分的间距 */
  margin-bottom: 0rpx;
  flex-shrink: 0;      /* 防止底部卡片被压缩 */
  width: 100%;
}

.container-expanded .focus-grid {
  padding-bottom: 24rpx;
}

.focus-grid .today-card {
  margin-bottom: 0rpx; /* 让 flex 容器的 gap 控制间距 */
}

/* 根据版块个性化定制左侧指示条颜色 */
.today-food::before {
  background: #E9C46A !important; /* 🍕 吃什么指示条采用明亮黄色 */
}

.today-date::before {
  background: #2A9D8F !important; /* 📍 去哪玩指示条采用自然绿色 */
}


.focus-card {
  min-height: 136rpx;
  padding: 18rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 105, 201, 0.02);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.focus-card:active {
  transform: scale(0.985);
}

.focus-card-head {
  display: flex;
  align-items: center;
  min-width: 0;
}

.focus-mark {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  background: #7C69C9;
  flex-shrink: 0;
}

.focus-memo .focus-mark { background: #4A90E2; }
.focus-anniversary .focus-mark { background: #FF6B6B; }
.focus-food .focus-mark { background: #E9C46A; }
.focus-date .focus-mark { background: #2A9D8F; }

.focus-label {
  min-width: 0;
  flex: 1;
  font-size: 21rpx;
  font-weight: 800;
  color: #9A95A8;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.focus-title {
  margin-top: 10rpx;
  min-height: 38rpx;
  font-size: 25rpx;
  font-weight: 800;
  color: #2D2938;
  line-height: 1.25;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
}

.focus-title-empty {
  font-size: 22rpx !important;
  font-weight: 700 !important;
  color: #B5B2C0 !important;
}

.focus-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  font-weight: 800;
  color: #7C69C9;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.urgent-card {
  background: linear-gradient(135deg, #FFF2F0 0%, #FFFFFF 100%);
  border-color: rgba(255, 77, 79, 0.7);
  box-shadow: 0 10rpx 28rpx rgba(255, 77, 79, 0.12);
  animation: urgentPulse 1.8s ease-in-out infinite;
}

.urgent-card .focus-label,
.urgent-card .focus-meta {
  color: #D4380D;
}

@keyframes urgentPulse {
  0%, 100% { box-shadow: 0 10rpx 28rpx rgba(255, 77, 79, 0.12); }
  50% { box-shadow: 0 12rpx 34rpx rgba(255, 77, 79, 0.24); }
}

/* 空间快速切换栏 */
.space-quick-bar {
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(45, 41, 56, 0.05);
  box-shadow: 0 8rpx 20rpx rgba(45, 41, 56, 0.02);
}

.space-quick-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  display: flex;
  align-items: center;
}

.quick-icon {
  margin-right: 12rpx;
  font-size: 34rpx;
}

.quick-arrow {
  font-size: 18rpx;
  color: #868095;
  margin-left: 12rpx;
}

.space-quick-badge {
  font-size: 22rpx;
  color: #7C69C9;
  background-color: #F3F0FA;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 800;
}
