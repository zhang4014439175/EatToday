<view class="container">
  <!-- 1. 顶部聚焦头图看板 -->
  <view class="focus-header">
    <view class="focus-bg-glow"></view>
    <view class="focus-content" wx:if="{{nearestAnn}}">
      <text class="focus-label">最近焦点倒计时</text>
      <view class="focus-title">{{nearestAnn.title}}</view>
      <view class="focus-days flex-row">
        <text class="days-num">{{nearestAnn.daysLeft}}</text>
        <text class="days-unit">天</text>
      </view>
      <text class="focus-date">📅 日期: {{nearestAnn.date}} {{nearestAnn.is_yearly ? '(每年重复)' : '(单次)'}}</text>
    </view>
    <view class="focus-content flex-column" wx:else style="display: flex; align-items: center; justify-content: center; height: 100%;">
      <text class="focus-title" style="font-size: 32rpx; margin-top: 20rpx;">生活需要仪式感 💖</text>
      <text class="focus-date" style="margin-top: 10rpx;">点击下方按钮，开始记录第一个纪念日吧</text>
    </view>
  </view>

  <!-- 主体内容卡片 -->
  <view class="main-body card">
    <!-- 2. 分类 Tab 切换 -->
    <view class="tab-container">
      <view class="tab-item {{activeTab === 'countdown' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="countdown">
        倒数日子 (倒计时)
      </view>
      <view class="tab-item {{activeTab === 'countup' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="countup">
        累计日子 (已过去)
      </view>
    </view>

    <!-- 3. 纪念日列表 -->
    <scroll-view scroll-y class="list-scroll">
      <!-- 倒计时列表 -->
      <view class="ann-list" wx:if="{{activeTab === 'countdown'}}">
        <view class="ann-item flex-row flex-between" wx:for="{{countdownList}}" wx:key="id">
          <view class="ann-info-box flex-row">
            <view class="ann-status-dot dot-countdown"></view>
            <view class="ann-text-details">
              <view class="flex-row" style="display: flex; align-items: center; gap: 12rpx;">
                <text class="ann-title-text">{{item.title}}</text>
                <text class="space-badge">{{item.space_name}}</text>
              </view>
              <view class="ann-sub-info text-muted">
                {{item.date}} {{item.is_yearly ? '每年重复' : '单次'}}
              </view>
            </view>
          </view>
          <view class="ann-right-box flex-row">
            <view class="days-badge badge-countdown">
              <text class="badge-num">{{item.daysLeft}}</text>
              <text class="badge-unit">天后</text>
            </view>
            <view class="delete-action-btn" bindtap="confirmDelete" data-id="{{item.id}}" data-title="{{item.title}}">✕</view>
          </view>
        </view>
        
        <view class="empty-hint text-center" wx:if="{{countdownList.length === 0}}">
          暂无未来的倒数日子...
        </view>
      </view>

      <!-- 累计天数列表 -->
      <view class="ann-list" wx:else>
        <view class="ann-item flex-row flex-between" wx:for="{{countupList}}" wx:key="id">
          <view class="ann-info-box flex-row">
            <view class="ann-status-dot dot-countup"></view>
            <view class="ann-text-details">
              <view class="flex-row" style="display: flex; align-items: center; gap: 12rpx;">
                <text class="ann-title-text">{{item.title}}</text>
                <text class="space-badge">{{item.space_name}}</text>
              </view>
              <view class="ann-sub-info text-muted">
                {{item.date}} 起已累计
              </view>
            </view>
          </view>
          <view class="ann-right-box flex-row">
            <view class="days-badge badge-countup">
              <text class="badge-num">{{item.daysElapsed}}</text>
              <text class="badge-unit">天</text>
            </view>
            <view class="delete-action-btn" bindtap="confirmDelete" data-id="{{item.id}}" data-title="{{item.title}}">✕</view>
          </view>
        </view>
        
        <view class="empty-hint text-center" wx:if="{{countupList.length === 0}}">
          暂无已过去的历史累计日子...
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 4. 固定底部新增按钮 -->
  <view class="fixed-bottom-bar">
    <button class="btn btn-primary add-big-btn" hover-class="btn-primary-hover" bindtap="openAddModal">
      + 新增纪念日
    </button>
  </view>

  <!-- 5. 新增半屏弹层 Modal -->
  <view class="modal-overlay" wx:if="{{showAddModal}}" bindtap="closeAddModal">
    <view class="modal-bottom-sheet card" catchtap="dummy">
      <view class="modal-header flex-row flex-between">
        <text class="modal-title-text">新增重要日子</text>
        <text class="modal-close-icon" bindtap="closeAddModal">×</text>
      </view>

      <view class="modal-body-form">
        <!-- 名字 -->
        <view class="form-group">
          <text class="form-label-text">纪念日名称</text>
          <input class="form-input" placeholder="例如：恋爱纪念日/我的生日" value="{{newAnn.title}}" bindinput="onInputTitle" />
        </view>

        <!-- 日期 -->
        <view class="form-group">
          <text class="form-label-text">选择日期</text>
          <picker mode="date" value="{{newAnn.date}}" bindchange="onDateChange">
            <view class="form-picker-box">{{newAnn.date || '点击选择日期'}}</view>
          </picker>
        </view>

        <!-- 重复开关 -->
        <view class="form-group flex-row flex-between" style="display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0;">
          <text class="form-label-text" style="margin-bottom: 0;">每年重复 (如生日/恋爱日)</text>
          <switch checked="{{newAnn.isYearly}}" color="#7C69C9" bindchange="onYearlyChange" />
        </view>

        <!-- 空间选择 -->
        <view class="form-group">
          <text class="form-label-text">归属空间</text>
          <picker mode="selector" range="{{spaces}}" range-key="name" bindchange="onSpaceChange">
            <view class="form-picker-box">
              {{selectedSpaceName || '选择该纪念日所在的共享空间'}}
            </view>
          </picker>
        </view>

        <!-- 确认保存 -->
        <button class="btn btn-primary" hover-class="btn-primary-hover" bindtap="submitAnniversary" style="margin-top: 48rpx; width: 100%;">
          确认并保存
        </button>
      </view>
    </view>
  </view>
</view>
