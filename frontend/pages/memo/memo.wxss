page {
  background-color: #FAF9FC;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.memo-header-card,
.form-card,
.list-card {
  padding: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
}

.page-kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #7C69C9;
  background: #F3F0FA;
  display: inline-flex;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.page-title {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 950;
  color: #2D2938;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #868095;
  line-height: 1.5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2D2938;
  margin-bottom: 24rpx;
}

.form-label-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 14rpx;
  display: block;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.form-picker-box {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  background-color: #FAF9FC;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #2D2938;
  font-weight: 700;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
}

.submit-btn {
  width: 100%;
  margin-top: 12rpx;
}

.card-header {
  align-items: center;
  margin-bottom: 8rpx;
}

.card-header .section-title {
  margin-bottom: 0;
}

.count-badge {
  font-size: 22rpx;
  font-weight: 900;
  color: #7C69C9;
  background: #F3F0FA;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.memo-list {
  margin-top: 18rpx;
}

.memo-item {
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.06);
}

.memo-item:last-child {
  border-bottom: none;
}

.memo-status {
  width: 12rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #4A90E2;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.memo-main {
  min-width: 0;
  flex: 1;
}

.memo-title {
  font-size: 28rpx;
  font-weight: 850;
  color: #2D2938;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.memo-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #868095;
}

.memo-delete {
  margin-left: 20rpx;
  font-size: 23rpx;
  font-weight: 900;
  color: #FF4D4F;
  background: #FFF2F0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.empty-state {
  padding: 90rpx 0;
  text-align: center;
  color: #868095;
  font-size: 24rpx;
  font-weight: 700;
}
