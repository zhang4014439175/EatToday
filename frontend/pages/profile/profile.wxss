.profile-header {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4E1);
  border: 1rpx solid rgba(255, 105, 180, 0.15);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(255, 105, 180, 0.1);
  background-color: #ffe4e1;
}

.user-meta {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 24rpx;
  color: #777777;
}

.copy-link {
  color: #FF69B4;
  font-weight: bold;
  margin-left: 15rpx;
  text-decoration: underline;
  padding: 5rpx 10rpx;
}

.login-mini-btn {
  background: linear-gradient(135deg, #FF69B4, #FFA07A);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 30rpx;
  padding: 10rpx 30rpx;
  display: inline-block;
  line-height: normal;
  margin: 0 !important;
  width: auto !important;
}

/* 牵线绑定卡片 */
.pairing-card {
  padding: 40rpx 30rpx;
}

.paired-view {
  justify-content: center;
  margin: 30rpx 0;
}

.couple-avatar-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.avatar-lg {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF0F5;
  box-shadow: 0 6rpx 16rpx rgba(255, 105, 180, 0.15);
  background-color: #ffe4e1;
}

.avatar-name {
  font-size: 24rpx;
  color: #666666;
  font-weight: bold;
  margin-top: 12rpx;
  background-color: #FFE4E1;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.couple-heart {
  font-size: 64rpx;
  margin: 0 60rpx;
  animation: pulseBeat 1.2s infinite alternate ease-in-out;
}

@keyframes pulseBeat {
  from { transform: scale(0.9); }
  to { transform: scale(1.15); }
}

.unpair-box {
  margin-top: 24rpx;
}

.unpair-link {
  font-size: 24rpx;
  color: #999999;
  text-decoration: underline;
  cursor: pointer;
}

.unpair-link:active {
  color: #ff3333;
}

.hint-text {
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 30rpx;
  text-align: left;
}

.pair-input-box {
  margin-bottom: 10rpx;
}

.pair-input {
  flex: 1;
  margin-bottom: 0;
  margin-right: 20rpx;
  height: 80rpx;
  text-align: center;
  font-weight: bold;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

.btn-pair-submit {
  background: linear-gradient(135deg, #FF69B4, #FFA07A);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 45rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(255, 105, 180, 0.2);
}

/* 纪念日管理 */
.add-anniversary-btn {
  font-size: 26rpx;
  color: #FF69B4;
  font-weight: bold;
}

.anniversary-form {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed #FFF0F5;
  animation: slideDown 0.3s ease-out;
}

.form-switch-group {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #555555;
  font-weight: 500;
}

.anniversary-list {
  max-height: 450rpx;
  overflow-y: auto;
}

.anniversary-item {
  padding: 24rpx 10rpx;
  border-bottom: 1rpx solid #FFF0F5;
}

.ann-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #444444;
  margin-bottom: 8rpx;
}

.ann-date {
  font-size: 24rpx;
}

/* 系统设置 */
.setting-item {
  padding: 10rpx 0;
}

.setting-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #444444;
  margin-bottom: 6rpx;
}

.logout-btn {
  margin-top: 40rpx;
}
