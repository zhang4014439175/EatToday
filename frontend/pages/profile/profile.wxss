.profile-header {
  padding: 44rpx 36rpx;
  align-items: center;
  background-color: #F3F0FA;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  border: 6rpx solid #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(45, 41, 56, 0.08);
  background-color: #F3F0FA;
  flex-shrink: 0;
}

.user-meta {
  margin-left: 32rpx;
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 38rpx;
  font-weight: 900;
  color: #2D2938;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: #868095;
  font-weight: 700;
  display: flex;
  align-items: center;
}

.copy-link {
  color: #7C69C9;
  font-weight: 800;
  margin-left: 16rpx;
  background-color: #F3F0FA;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  transition: all 0.2s ease;
}

.copy-link:active {
  background-color: #EAE5F6;
}

.login-mini-btn {
  background: #7C69C9;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 999rpx;
  padding: 0 36rpx;
  height: 64rpx;
  line-height: 64rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  width: auto !important;
  box-shadow: 0 8rpx 20rpx rgba(124, 105, 201, 0.2);
}

/* 空间管理卡片 */
.space-card {
  padding: 40rpx 36rpx;
  background: #ffffff;
}

.active-badge {
  font-size: 22rpx;
  color: #7C69C9;
  background-color: #F3F0FA;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 800;
}

.current-space-info {
  background: linear-gradient(135deg, #FAF8FF 0%, #F5F0FF 100%);
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(124, 105, 201, 0.03);
}

.space-left-box {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.space-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.space-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(124, 105, 201, 0.06);
  flex-shrink: 0;
}

.space-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #2D2938;
}

.space-code-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #868095;
  font-weight: 700;
}

.space-code {
  color: #2D2938;
  font-weight: 900;
  background: #ffffff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
  margin: 0 10rpx;
  letter-spacing: 1rpx;
}

.copy-link {
  color: #7C69C9;
  font-weight: 800;
  text-decoration: underline;
  cursor: pointer;
}

.space-right-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding-left: 20rpx;
}

.switch-btn-text {
  font-size: 22rpx;
  color: #868095;
  font-weight: 800;
}

.switch-arrow {
  font-size: 28rpx;
  color: #868095;
  line-height: 1;
}

/* 空间成员列表 */
.member-section {
  margin-bottom: 36rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #868095;
  margin-bottom: 20rpx;
}

.members-grid {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.avatar-wrapper {
  position: relative;
  width: 90rpx;
  height: 90rpx;
}

.member-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(45, 41, 56, 0.08);
  background-color: #F3F0FA;
}

.role-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: #7C69C9;
  color: #ffffff;
  font-size: 14rpx;
  font-weight: 900;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(124, 105, 201, 0.3);
}

.member-name {
  font-size: 22rpx;
  color: #2D2938;
  font-weight: 700;
  margin-top: 12rpx;
  width: 100%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 切换其它空间列表 */
.switch-section {
  margin-bottom: 32rpx;
  border-top: 1rpx solid rgba(45, 41, 56, 0.05);
  padding-top: 24rpx;
}

.spaces-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.space-item {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #F9F9FB;
  border: 1rpx solid rgba(45, 41, 56, 0.02);
  align-items: center;
}

.space-item.active {
  background: #F3F0FA;
  border-color: rgba(124, 105, 201, 0.15);
}

.space-item-left {
  align-items: center;
}

.space-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.space-item-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2D2938;
}

.space-item-right {
  align-items: center;
  gap: 12rpx;
}

.member-count-badge {
  font-size: 20rpx;
  color: #868095;
  font-weight: 700;
}

.active-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #7C69C9;
}

/* 空间操作面板 (Tab/Input) */
.space-actions {
  border-top: 1rpx solid rgba(45, 41, 56, 0.05);
  padding-top: 32rpx;
}

.action-tab-header {
  background: #F3F0FA;
  border-radius: 999rpx;
  padding: 6rpx;
  display: flex;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.action-tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  color: #868095;
  padding: 14rpx 0;
  border-radius: 999rpx;
  transition: all 0.25s ease;
}

.action-tab.active {
  color: #7C69C9;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(124, 105, 201, 0.1);
}

.action-panel {
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.input-btn-group {
  gap: 16rpx;
}

.action-input {
  flex: 1;
  margin-bottom: 0;
  height: 72rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
}

.btn-action-submit {
  background: #7C69C9;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(124, 105, 201, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  width: auto !important;
}

.leave-box {
  margin-top: 24rpx;
  text-align: center;
}

.leave-link {
  font-size: 22rpx;
  color: #ff4d4f;
  text-decoration: underline;
}

.leave-link:active {
  color: #cf1322;
}

/* 纪念日管理 */
.anniversary-card {
  background-color: #FFFFFF;
  border: 1rpx solid rgba(45, 41, 56, 0.06);
}

.anniversary-card .card-title::before {
  background: #7C69C9;
}

.add-anniversary-btn {
  font-size: 24rpx;
  color: #ffffff;
  background-color: #7C69C9;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.add-anniversary-btn:active {
  background-color: #6B57B8;
}

.anniversary-form {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.05);
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-switch-group {
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #2D2938;
  font-weight: 700;
}

.anniversary-list {
  max-height: 480rpx;
}

.anniversary-item {
  padding: 28rpx 8rpx;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.05);
  align-items: center;
}

.anniversary-item:last-child {
  border-bottom: none;
}

.ann-info {
  flex: 1;
  min-width: 0;
}

.ann-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 8rpx;
}

.ann-date {
  font-size: 24rpx;
  font-weight: 700;
  color: #868095;
}

/* 系统设置 */
.settings-card {
  background-color: #FFFFFF;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
}

.setting-item {
  padding: 24rpx 0;
  align-items: center;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.04);
}

.setting-item:last-of-type {
  border-bottom: none;
}

.setting-info {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 8rpx;
}

.logout-btn {
  margin-top: 36rpx;
}
