.profile-header {
  padding: 44rpx 36rpx;
  align-items: center;
  background-color: #F3F0FA;
  border: 1rpx solid rgba(124, 105, 201, 0.08);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  border: 6rpx solid #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(45, 41, 56, 0.08);
  background-color: #F3F0FA;
  flex-shrink: 0;
}

.user-meta {
  margin-left: 32rpx;
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 38rpx;
  font-weight: 900;
  color: #2D2938;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 24rpx;
  color: #868095;
  font-weight: 700;
  display: flex;
  align-items: center;
}

.copy-link {
  color: #7C69C9;
  font-weight: 800;
  margin-left: 16rpx;
  background-color: #F3F0FA;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  transition: all 0.2s ease;
}

.copy-link:active {
  background-color: #EAE5F6;
}

.login-mini-btn {
  background: #7C69C9;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 999rpx;
  padding: 0 36rpx;
  height: 64rpx;
  line-height: 64rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  width: auto !important;
  box-shadow: 0 8rpx 20rpx rgba(124, 105, 201, 0.2);
}

/* 牵线绑定卡片 */
.pairing-card {
  padding: 40rpx 36rpx;
}

.paired-view {
  justify-content: center;
  align-items: center;
  margin: 40rpx 0 20rpx;
}

.couple-avatar-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.avatar-lg {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  border: 6rpx solid #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(45, 41, 56, 0.1);
  background-color: #F3F0FA;
}

.avatar-name {
  font-size: 22rpx;
  color: #7C69C9;
  font-weight: 800;
  margin-top: 16rpx;
  background-color: #F3F0FA;
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
}

.couple-heart {
  font-size: 64rpx;
  margin: 0 48rpx;
  display: inline-block;
}

.unpair-box {
  margin-top: 32rpx;
}

.unpair-link {
  font-size: 24rpx;
  color: #868095;
  text-decoration: underline;
  transition: color 0.2s ease;
}

.unpair-link:active {
  color: #7C69C9;
}

.hint-text {
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 32rpx;
  color: #868095;
}

.pair-input-box {
  gap: 16rpx;
}

.pair-input {
  flex: 1;
  margin-bottom: 0;
  height: 84rpx;
  text-align: center;
  font-weight: 800;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

.btn-pair-submit {
  background: #7C69C9;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 44rpx;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 24rpx rgba(124, 105, 201, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 纪念日管理 */
.anniversary-card {
  background-color: #FFFFFF;
  border: 1rpx solid rgba(45, 41, 56, 0.06);
}

.anniversary-card .card-title::before {
  background: #7C69C9;
}

.add-anniversary-btn {
  font-size: 24rpx;
  color: #ffffff;
  background-color: #7C69C9;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.add-anniversary-btn:active {
  background-color: #6B57B8;
}

.anniversary-form {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.05);
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-switch-group {
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #2D2938;
  font-weight: 700;
}

.anniversary-list {
  max-height: 480rpx;
}

.anniversary-item {
  padding: 28rpx 8rpx;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.05);
  align-items: center;
}

.anniversary-item:last-child {
  border-bottom: none;
}

.ann-info {
  flex: 1;
  min-width: 0;
}

.ann-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 8rpx;
}

.ann-date {
  font-size: 24rpx;
  font-weight: 700;
  color: #868095;
}

/* 系统设置 */
.settings-card {
  background-color: #FFFFFF;
  border: 1rpx solid rgba(45, 41, 56, 0.04);
}

.setting-item {
  padding: 24rpx 0;
  align-items: center;
  border-bottom: 1rpx solid rgba(45, 41, 56, 0.04);
}

.setting-item:last-of-type {
  border-bottom: none;
}

.setting-info {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D2938;
  margin-bottom: 8rpx;
}

.logout-btn {
  margin-top: 36rpx;
}
