<view class="container">
  <!-- 1. 用户头像与基础登录块 -->
  <view class="card profile-header flex-row">
    <!-- 头像容器：如果登录了点击可更换头像 -->
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatar_url || '/images/default_avatar.png'}}" mode="aspectFill" style="margin: 0;" />
    </button>
    <image class="avatar" src="/images/default_avatar.png" mode="aspectFill" wx:else />
    <view class="user-meta" wx:if="{{isLogin}}">
      <view class="nickname" bindtap="editNickname">
        {{userInfo.nickname}}
      </view>
      <view class="user-id">配对码：{{userInfo.pair_code}} <text class="copy-link" bindtap="copyPairCode">复制</text></view>
    </view>
    <view class="user-meta" wx:else>
      <view class="nickname">欢迎加入 EatToday</view>
      <button class="login-mini-btn" bindtap="handleLogin">一键登录</button>
    </view>
  </view>

  <!-- 2. 空间管理与成员卡片 -->
  <view class="card space-card" wx:if="{{isLogin}}">
    <view class="card-header flex-row flex-between" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; width: 100%;">
      <view class="card-title" style="margin-bottom: 0;">当前空间</view>
      <view class="active-badge">{{currentSpace.type === 'solo' ? '个人空间' : '群组空间'}}</view>
    </view>
    
    <!-- 空间基础详情 -->
    <view class="current-space-info flex-row" bindtap="onTapSpaceSwitcher">
      <view class="space-left-box">
        <view class="space-name-row flex-row">
          <view class="space-icon-wrapper">
            <text>🏠</text>
          </view>
          <text class="space-name">{{currentSpace.name || '默认空间'}}</text>
        </view>
        <view class="space-code-row flex-row" wx:if="{{currentSpace.type !== 'solo'}}" catchtap="dummy">
          <text class="space-code-label">邀请码：</text>
          <text class="space-code">{{currentSpace.code}}</text>
          <text class="copy-link" bindtap="copySpaceCode">复制</text>
        </view>
      </view>
      <view class="space-right-box flex-row">
        <text class="switch-btn-text">切换空间</text>
        <text class="switch-arrow">›</text>
      </view>
    </view>
 
    <!-- 空间成员列表 -->
    <view class="member-section" wx:if="{{spaceMembers.length > 0}}">
      <view class="section-title">空间成员 ({{spaceMembers.length}}人)</view>
      <view class="members-grid flex-row">
        <view class="member-item" wx:for="{{spaceMembers}}" wx:key="id">
          <view class="avatar-wrapper">
            <image class="member-avatar" src="{{item.avatar_url || '/images/default_avatar.png'}}" mode="aspectFill" />
            <view class="role-badge" wx:if="{{item.role === 'admin'}}">管理员</view>
          </view>
          <view class="member-name">{{item.nickname || '用户'}}</view>
        </view>
      </view>
    </view>

    <!-- 空间操作面板 (创建/加入/退出) -->
    <view class="space-actions" style="margin-top: 24rpx; width: 100%;">
      <!-- 邀请按钮 (只限 solo 空间时展示，且需要登录) -->
      <button class="btn-invite-partner" open-type="share" data-type="invite-double" wx:if="{{currentSpace.type === 'solo'}}" style="margin-bottom: 20rpx; width: 100%; height: 84rpx; background: linear-gradient(135deg, #7C69C9, #9C8BE2); color: #ffffff; border-radius: 42rpx; font-size: 26rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx rgba(124, 105, 201, 0.2); border: none;">
        邀请好友建立双人共享空间
      </button>

      <!-- 邀请按钮 (当前空间不是个人空间时展示) -->
      <button class="btn-invite-friend" open-type="share" data-type="invite-to-space" wx:if="{{currentSpace && currentSpace.type !== 'solo'}}" style="margin-bottom: 20rpx; width: 100%; height: 84rpx; background: linear-gradient(135deg, #3E8E75, #5CAF93); color: #ffffff; border-radius: 42rpx; font-size: 26rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx rgba(62, 142, 117, 0.2); border: none;">
        👥 邀请好友加入当前空间
      </button>

      <!-- 加入/新建双人空间按钮组合 -->
      <view class="action-btn-row" style="display: flex; gap: 16rpx; width: 100%;">
        <button class="action-btn-pill" bindtap="handleJoinSpacePopup" style="flex: 1; height: 72rpx; border-radius: 36rpx; background: #FAF9FC; color: #7C69C9; border: 1rpx solid rgba(124, 105, 201, 0.25); font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 6rpx rgba(124, 105, 201, 0.02); padding: 0; min-height: 72rpx; line-height: 72rpx;">
          加入已有空间
        </button>
        <button class="action-btn-pill" bindtap="handleCreateSpacePopup" style="flex: 1; height: 72rpx; border-radius: 36rpx; background: #FAF9FC; color: #7C69C9; border: 1rpx solid rgba(124, 105, 201, 0.25); font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 6rpx rgba(124, 105, 201, 0.02); padding: 0; min-height: 72rpx; line-height: 72rpx;">
          新建空间
        </button>
      </view>

      <!-- 退出当前空间 (只限非 solo 空间) -->
      <view class="leave-box" wx:if="{{currentSpace.type !== 'solo'}}" style="margin-top: 24rpx; text-align: center;">
        <text class="leave-link" bindtap="handleLeaveCurrentSpace" style="font-size: 24rpx; color: #FF4D4F; font-weight: bold; text-decoration: underline;">退出当前空间</text>
      </view>
    </view>
  </view>

  <!-- 3. 纪念日簿入口 -->
  <view class="card anniversary-entry-card" wx:if="{{isLogin}}" bindtap="goToAnniversaryBook" style="display: flex; justify-content: space-between; align-items: center; padding: 36rpx 28rpx; cursor: pointer; margin-bottom: 24rpx; background: #ffffff; border-radius: 24rpx; box-shadow: 0 8rpx 24rpx rgba(45, 41, 56, 0.02); border: 1rpx solid rgba(45, 41, 56, 0.04);">
    <view class="flex-row" style="display: flex; align-items: center; gap: 20rpx;">
      <view style="font-size: 38rpx; width: 64rpx; height: 64rpx; background: #F3F0FA; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; color: #7C69C9;">📅</view>
      <view>
        <view style="font-size: 28rpx; font-weight: 800; color: #2D2938;">纪念日簿</view>
        <view style="font-size: 22rpx; color: #868095; margin-top: 4rpx;">记录并管理我们所有重要的倒计时与累计日</view>
      </view>
    </view>
    <text style="font-size: 26rpx; color: #868095; font-weight: 800;">➔</text>
  </view>

  <!-- 4. 其它应用设置 -->
  <view class="card settings-card" wx:if="{{isLogin}}">
    <view class="card-title">系统设置</view>
    
    <view class="setting-item flex-row flex-between">
      <view class="setting-info">
        <view class="setting-name">去哪玩变动提醒推送</view>
        <view class="text-muted">当对方修改或接受去哪玩提案时发送通知</view>
      </view>
      <switch checked="{{settings.dateNotify}}" color="#7C69C9" bindchange="toggleDateNotify" />
    </view>

    <view class="setting-item flex-row flex-between" style="border-top: 1rpx solid #FFF0F5; margin-top:20rpx; padding-top:20rpx;">
      <view class="setting-info">
        <view class="setting-name">今天吃什么提醒</view>
        <view class="text-muted">每天饭点前提醒共同投票决定吃什么</view>
      </view>
      <switch checked="{{settings.foodNotify}}" color="#7C69C9" bindchange="toggleFoodNotify" />
    </view>

    <button class="btn btn-secondary logout-btn" hover-class="btn-secondary-hover" bindtap="handleLogout">退出登录</button>
    <button class="btn btn-danger delete-account-btn" hover-class="btn-danger-hover" bindtap="handleDeleteAccount" style="margin-top: 24rpx; background-color: #FFF2F0; color: #FF4D4F; border: 1rpx solid #FFA39E; border-radius: 999rpx; font-weight: 800; font-size: 26rpx; height: 88rpx; line-height: 88rpx; width: 100%;">注销并销毁账号</button>
  </view>

  <!-- 5. 占位默认头像图生成说明（无需展示给用户） -->
</view>
