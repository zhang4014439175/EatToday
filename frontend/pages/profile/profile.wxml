<view class="container">
  <!-- 1. 用户头像与基础登录块 -->
  <view class="card profile-header flex-row">
    <image class="avatar" src="{{userInfo.avatar_url || '/images/default_avatar.png'}}" mode="aspectFill" />
    <view class="user-meta" wx:if="{{isLogin}}">
      <view class="nickname">{{userInfo.nickname}}</view>
      <view class="user-id">配对码：{{userInfo.pair_code}} <text class="copy-link" bindtap="copyPairCode">复制</text></view>
    </view>
    <view class="user-meta" wx:else>
      <view class="nickname">欢迎加入 EatToday</view>
      <button class="login-mini-btn" bindtap="handleLogin">一键登录</button>
    </view>
  </view>

  <!-- 2. 空间管理与成员卡片 -->
  <view class="card space-card" wx:if="{{isLogin}}">
    <view class="card-header flex-row flex-between" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; width: 100%;">
      <view class="card-title" style="margin-bottom: 0;">当前空间</view>
      <view class="active-badge">{{currentSpace.type === 'solo' ? '个人空间' : '群组空间'}}</view>
    </view>
    
    <!-- 空间基础详情 -->
    <view class="current-space-info" bindtap="onTapSpaceSwitcher" style="cursor: pointer;">
      <view class="space-name-row flex-row" style="display: flex; align-items: center; justify-content: space-between;">
        <view class="flex-row" style="display: flex; align-items: center;">
          <text class="space-emoji">🏠</text>
          <text class="space-name">{{currentSpace.name || '默认空间'}}</text>
          <text class="quick-arrow" style="margin-left: 10rpx; font-size: 20rpx; color: #868095;">▼</text>
        </view>
        <text class="switch-tip-text" style="font-size: 22rpx; color: #7C69C9; font-weight: bold; background: #F3F0FA; padding: 4rpx 14rpx; border-radius: 6rpx;">切换</text>
      </view>
      <view class="space-code-row flex-row" wx:if="{{currentSpace.type !== 'solo'}}" catchtap="dummy">
        <text class="space-code-label">邀请码：</text>
        <text class="space-code">{{currentSpace.code}}</text>
        <text class="copy-link" bindtap="copySpaceCode">复制</text>
      </view>
    </view>
 
    <!-- 空间成员列表 -->
    <view class="member-section" wx:if="{{spaceMembers.length > 0}}">
      <view class="section-title">空间成员 ({{spaceMembers.length}}人)</view>
      <view class="members-grid flex-row">
        <view class="member-item" wx:for="{{spaceMembers}}" wx:key="id">
          <image class="member-avatar" src="{{item.avatar_url || '/images/default_avatar.png'}}" mode="aspectFill" />
          <view class="member-role {{item.role === 'admin' ? 'admin' : ''}}">{{item.role === 'admin' ? '管理员' : '成员'}}</view>
          <view class="member-name">{{item.nickname || '用户'}}</view>
        </view>
      </view>
    </view>

    <!-- 空间操作面板 (创建/加入/退出) -->
    <view class="space-actions">
      <!-- 选项按钮，用来展开不同的输入面板 -->
      <view class="action-tab-header flex-row">
        <view class="action-tab {{activeTab === 'join' ? 'active' : ''}}" bindtap="switchActionTab" data-tab="join">加入群组</view>
        <view class="action-tab {{activeTab === 'create' ? 'active' : ''}}" bindtap="switchActionTab" data-tab="create">新建群组</view>
      </view>

      <!-- 加入空间面板 -->
      <view class="action-panel" wx:if="{{activeTab === 'join'}}">
        <view class="flex-row input-btn-group">
          <input class="form-input action-input" placeholder="输入6位空间邀请码" value="{{inputSpaceCode}}" bindinput="onInputSpaceCode" />
          <button class="btn-action-submit" bindtap="handleJoinSpace">加入</button>
        </view>
      </view>

      <!-- 创建空间面板 -->
      <view class="action-panel" wx:if="{{activeTab === 'create'}}">
        <view class="flex-row input-btn-group">
          <input class="form-input action-input" placeholder="输入空间名称" value="{{inputSpaceName}}" bindinput="onInputSpaceName" />
          <button class="btn-action-submit" bindtap="handleCreateSpace">创建</button>
        </view>
      </view>
      
      <!-- 退出当前空间 (只限非 solo 空间) -->
      <view class="leave-box" wx:if="{{currentSpace.type !== 'solo'}}">
        <text class="leave-link" bindtap="handleLeaveCurrentSpace">退出当前空间</text>
      </view>
    </view>
  </view>

  <!-- 3. 纪念日管理卡片 -->
  <view class="card anniversary-card" wx:if="{{isLogin}}">
    <view class="card-header flex-row flex-between" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; width: 100%;">
      <view class="card-title" style="margin-bottom: 0;">重要日子管理</view>
      <text class="add-anniversary-btn" bindtap="showAddAnniversaryForm">{{showAddAnniversary ? '取消' : '+ 新增'}}</text>
    </view>

    <!-- 添加纪念日表单 -->
    <view class="anniversary-form" wx:if="{{showAddAnniversary}}">
      <input class="form-input" placeholder="纪念日名称 (例如：恋爱纪念日/宝贝生日)" value="{{newAnniversary.title}}" bindinput="onInputAnnTitle" />
      
      <picker mode="date" value="{{newAnniversary.date}}" bindchange="onAnnDateChange">
        <view class="picker-box" style="margin-bottom: 20rpx;">{{newAnniversary.date || '选择日期'}}</view>
      </picker>

      <view class="flex-row flex-between form-switch-group">
        <text class="switch-label">是否每年重复</text>
        <switch checked="{{newAnniversary.is_yearly}}" color="#7C69C9" bindchange="onAnnYearlyChange" />
      </view>

      <button class="btn btn-primary" hover-class="btn-primary-hover" bindtap="submitAnniversary">保存纪念日</button>
    </view>

    <!-- 纪念日列表 -->
    <view class="anniversary-list">
      <view class="anniversary-item flex-row flex-between" wx:for="{{anniversaries}}" wx:key="id">
        <view class="ann-info">
          <view class="ann-title">🎉 {{item.title}}</view>
          <view class="ann-date text-muted">{{item.date}} {{item.is_yearly ? '(每年重复)' : '(单次)'}}</view>
        </view>
        <view class="food-delete-btn" bindtap="deleteAnniversary" data-id="{{item.id}}">✕</view>
      </view>
      <view class="empty-list" wx:if="{{anniversaries.length === 0}}">
        还没有添加纪念日，点击右上角加一个吧！
      </view>
    </view>
  </view>

  <!-- 4. 其它应用设置 -->
  <view class="card settings-card" wx:if="{{isLogin}}">
    <view class="card-title">系统设置</view>
    
    <view class="setting-item flex-row flex-between">
      <view class="setting-info">
        <view class="setting-name">去哪玩变动提醒推送</view>
        <view class="text-muted">当伴侣修改或接受去哪玩提案时发送通知</view>
      </view>
      <switch checked="{{settings.dateNotify}}" color="#7C69C9" bindchange="toggleDateNotify" />
    </view>

    <view class="setting-item flex-row flex-between" style="border-top: 1rpx solid #FFF0F5; margin-top:20rpx; padding-top:20rpx;">
      <view class="setting-info">
        <view class="setting-name">今天吃什么提醒</view>
        <view class="text-muted">每天饭点前提醒共同投票决定吃什么</view>
      </view>
      <switch checked="{{settings.foodNotify}}" color="#7C69C9" bindchange="toggleFoodNotify" />
    </view>

    <button class="btn btn-secondary logout-btn" hover-class="btn-secondary-hover" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 5. 占位默认头像图生成说明（无需展示给用户） -->
</view>
