/**app.wxss**/
page {
  background-color: #FFF5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #333333;
  box-sizing: border-box;
}

/* 全局容器 */
.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 温馨卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 105, 180, 0.06);
  border: 1rpx solid rgba(255, 182, 193, 0.15);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #E066FF;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: "❤";
  color: #FF69B4;
  margin-right: 12rpx;
  font-size: 28rpx;
}

/* 按钮系列 */
.btn {
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 22rpx 0;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  margin: 15rpx 0;
}

/* 主按钮 (爱心渐变粉) */
.btn-primary {
  background: linear-gradient(135deg, #FF69B4, #FFA07A);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(255, 105, 180, 0.3);
}

.btn-primary-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 次按钮 (淡粉紫) */
.btn-secondary {
  background-color: #FFE4E1;
  color: #FF69B4;
  border: 1rpx solid rgba(255, 105, 180, 0.3);
}

.btn-secondary-hover {
  background-color: #FFD1D1;
  color: #E0559D;
}

/* 表单输入域 */
.form-input {
  background-color: #FFF9FA;
  border: 2rpx solid #FFE4E1;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF69B4;
}

/* 辅助文本 */
.text-muted {
  color: #999999;
  font-size: 24rpx;
}

.text-center {
  text-align: center;
}

/* 垂直居中 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
}
